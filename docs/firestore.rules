rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ----- Helpers -----

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function isAuthed() {
      return request.auth != null;
    }
    function isAdmin() {
      return isAuthed() && userDoc().role == 'admin';
    }
    function isRH() {
      return isAuthed() && userDoc().role == 'rh';
    }
    function isLider() {
      return isAuthed() && userDoc().role == 'lider';
    }
    function isSupervisor() {
      return isAuthed() && userDoc().role == 'supervisor';
    }
    // ----- Portal do Colaborador (Fundação SELF) -----
    function isColaborador() {
      return isAuthed() && userDoc().role == 'colaborador';
    }
    // Vínculo SELF: funcionarioId gravado em users/{uid}. Ausente => '' (fail-safe: nunca casa
    // com id real => leitura negada). Defense-in-depth: a UI já filtra; isto é a rede de baixo.
    function meuFuncionarioId() {
      return isColaborador() && ('funcionarioId' in userDoc()) && userDoc().funcionarioId is string
        ? userDoc().funcionarioId : '';
    }
    function euSouODono(funcId) {
      return meuFuncionarioId() != '' && funcId == meuFuncionarioId();
    }
    function supervisorVe(funcId) {
      return isSupervisor()
        && userDoc().funcionariosVisiveis is list
        && userDoc().funcionariosVisiveis.hasAny([funcId]);
    }
    // Supervisor por TURNO (automação): cobre turnos inteiros (ex.: Aldo = 1,2,3).
    // O escopo efetivo do supervisor é supervisorVe (avulsos) OU supervisorVeTurno.
    function supervisorVeTurno(turno) {
      return isSupervisor()
        && userDoc().turnosVisiveis is list
        && userDoc().turnosVisiveis.hasAny([turno]);
    }
    function liderDoMesmoTurno(turno) {
      return isLider() && userDoc().turno == turno;
    }
    // READ amplo: supervisor lê todas as ocorrências (a UI filtra pela lista
    // dele). O escopo estrito (supervisorVe) é aplicado só no WRITE/conferir.
    function podeVerOcorrencia(doc) {
      return isAdmin() || isRH()
        || liderDoMesmoTurno(doc.funcionarioTurno)
        || isSupervisor();
    }

    // ----- Permissões data-driven (matriz editável) -----
    // Lê /config/permissoes (mapa { papel: { capability: valor } }). Se o doc
    // não existir OU não tiver a (papel, capability), cai no `fallback` — que é
    // SEMPRE a regra hardcoded de hoje. Logo: doc ausente/parcial = comportamento
    // idêntico ao atual. Admin é tratado à parte (sempre liberado) por quem chama.
    // valores "ligados": true | 'turno' | 'atrib'.
    function permDoc() {
      return exists(/databases/$(database)/documents/config/permissoes)
        ? get(/databases/$(database)/documents/config/permissoes).data
        : {};
    }
    // ATENCAO (invariante, Fable 2026-07-06): o retorno e BOOLEANO. Os valores 'turno' e
    // 'atrib' da matriz viram apenas "ligado"; o ESCOPO (filtrar por turno do lider, por
    // funcionariosVisiveis do supervisor) e SEMPRE aplicado hardcoded no match que usa a
    // cap, NUNCA inferido daqui. Cap scoped nova sem esse filtro no match = furo de acesso.
    function temCap(cap, fallback) {
      let m = permDoc();
      let role = userDoc().role;
      return isAuthed() && (
        (role in m && cap in m[role])
          ? (m[role][cap] == true || m[role][cap] == 'turno' || m[role][cap] == 'atrib')
          : fallback
      );
    }

    // Lista de benefícios (catálogo em config/vagas e os marcados por vaga). As rules
    // não iteram, então enumeramos os índices com curto-circuito por size (ponytail: a
    // linguagem não tem loop; o teto 30 casa o cap do catálogo e cobre o da vaga <=15).
    // Cada item precisa ser string 1..40; o CHAMADOR garante `is list` e o cap de tamanho
    // (30 catálogo, 15 vaga), então índices acima do size caem no curto-circuito. Guarda
    // de fronteira: config/vagas é PÚBLICO, um item gigante não pode ir pra internet.
    // Custo: `let n` calcula o size 1x e benefItem indexa cada elemento 1x, pra não
    // estourar o teto de 1000 expressões do Firestore com o catálogo cheio (30 itens).
    function benefItem(s) {
      return s is string && s.size() >= 1 && s.size() <= 40;
    }
    function benefStrings(l) {
      let n = l.size();
      return (n < 1  || benefItem(l[0]))
        && (n < 2  || benefItem(l[1]))
        && (n < 3  || benefItem(l[2]))
        && (n < 4  || benefItem(l[3]))
        && (n < 5  || benefItem(l[4]))
        && (n < 6  || benefItem(l[5]))
        && (n < 7  || benefItem(l[6]))
        && (n < 8  || benefItem(l[7]))
        && (n < 9  || benefItem(l[8]))
        && (n < 10 || benefItem(l[9]))
        && (n < 11 || benefItem(l[10]))
        && (n < 12 || benefItem(l[11]))
        && (n < 13 || benefItem(l[12]))
        && (n < 14 || benefItem(l[13]))
        && (n < 15 || benefItem(l[14]))
        && (n < 16 || benefItem(l[15]))
        && (n < 17 || benefItem(l[16]))
        && (n < 18 || benefItem(l[17]))
        && (n < 19 || benefItem(l[18]))
        && (n < 20 || benefItem(l[19]))
        && (n < 21 || benefItem(l[20]))
        && (n < 22 || benefItem(l[21]))
        && (n < 23 || benefItem(l[22]))
        && (n < 24 || benefItem(l[23]))
        && (n < 25 || benefItem(l[24]))
        && (n < 26 || benefItem(l[25]))
        && (n < 27 || benefItem(l[26]))
        && (n < 28 || benefItem(l[27]))
        && (n < 29 || benefItem(l[28]))
        && (n < 30 || benefItem(l[29]));
    }

    // ----- Pacote Gestor: segmentação (comunicados + documentos institucionais) -----
    // Colaborador casa com o segmento? 'todos' sempre; 'turno' por users.turno (canônico:
    // number 1|2|3 OU string 'geral'); 'setor' por users.setor denormalizado.
    // Ausência/null/tipo errado => false (fail-safe: nega). userDoc() é avaliado 1x e
    // passado como argumento (1 get por avaliação, conforme objetivo de custo).
    // DEPENDÊNCIA DE DADOS: users/{uid}.turno e .setor são denormalizados pelo pipeline
    // (sync-colaborador-users.mjs do WKRADAR). Até lá, só 'todos' resolve; turno/setor negam.
    function casaTurno(seg, u) {
      return ('turno' in u)
          && (u.turno is number || u.turno is string)
          && seg.valores.hasAny([u.turno]);
    }
    function casaSetor(seg, u) {
      return ('setor' in u)
          && u.setor is string
          && seg.valores.hasAny([u.setor]);
    }
    function casaSegmento(seg) {
      return seg.tipo == 'todos'
        || (seg.tipo == 'turno' && casaTurno(seg, userDoc()))
        || (seg.tipo == 'setor' && casaSetor(seg, userDoc()));
    }
    // institucional por segmento OU pessoal por dono (SELF)
    function podeVerDoc(d) {
      return (d.escopo == 'institucional' && casaSegmento(d.segmento))
          || (d.escopo == 'pessoal' && d.funcionarioId == meuFuncionarioId());
    }

    // ----- config (matriz de permissões + futuras configs do sistema) -----
    // Leitura: qualquer autenticado (o app monta o can() a partir daqui; sem
    // segredos). Escrita: só admin (gerencia a matriz).
    match /config/{doc} {
      allow read: if isAuthed();
      allow write: if isAdmin();
    }

    // ----- users -----
    // Admin lê todos; user lê só o próprio doc.
    // Admin (ou quem tiver sistema.usuarios) cria/deleta/edita qualquer campo.
    // O próprio user pode atualizar APENAS o campo fotoBase64 (foto de perfil)
    // — sem poder mexer em role, turno, ativo.
    match /users/{uid} {
      // Gestores leem o diretório inteiro (presença/Auditoria resolvem nome/papel/foto
      // por uid) — INALTERADO. Colaborador lê SÓ o próprio doc (sem diretório nesta fase).
      allow read: if isAdmin() || isRH() || isLider() || isSupervisor()
                  || (isColaborador() && request.auth.uid == uid);
      allow create, delete: if isAdmin() || temCap('sistema.usuarios', false);
      // Self-update: além de fotoBase64, o colaborador zera precisaTrocarSenha (troca no 1º acesso)
      // e equipa a decoração do avatar da gamificação (cosmético, lista fechada; o desbloqueio
      // real é validado na UI — forjar decoração não dá acesso a nada, residual aceito no gate).
      // Continua impedindo mexer em role/turno/ativo/funcionarioId.
      allow update: if isAdmin() || temCap('sistema.usuarios', false) || (
        request.auth.uid == uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['fotoBase64', 'precisaTrocarSenha', 'decoracao']) &&
        (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['decoracao'])
          || request.resource.data.decoracao in ['', 'bronze', 'prata', 'ouro', 'fio', 'veterano'])
      );
    }

    // ----- funcionarios -----
    match /funcionarios/{id} {
      // Gestores leem amplo (INALTERADO); colaborador só o próprio funcionário (escopo SELF).
      allow read: if isAdmin() || isRH() || isLider() || isSupervisor()
                  || (isColaborador() && euSouODono(id));
      allow create, update, delete: if isAdmin() || temCap('func.editar', isRH());
    }

    // ----- tipos (motivos customizados criados pela equipe) -----
    // Todos logados leem (pra popular o dropdown). Quem tem sistema.config edita.
    match /tipos/{id} {
      allow read: if isAuthed();
      allow create, update, delete: if isAdmin() || temCap('sistema.config', isRH());
    }

    // ----- acoes (ações customizadas — encaminhamento pelo líder) -----
    match /acoes/{id} {
      allow read: if isAuthed();
      allow create, update, delete: if isAdmin() || temCap('sistema.config', isRH());
    }

    // ----- obrigacoes (checklist recorrente do GH) -----
    // Todos logados leem (card/tela gated na UI por obrigacoes.gerenciar; sem
    // segredos). Escrita (cadastrar/editar/marcar conclusão): GH/admin.
    match /obrigacoes/{id} {
      allow read: if isAuthed();
      allow create, update, delete: if isAdmin() || temCap('obrigacoes.gerenciar', isRH());
    }

    // ----- bancoHoras (saldo de horas por funcionário · denormalizado por doc) -----
    // Líder lê apenas docs do próprio turno; supervisor lê amplo (UI filtra).
    // Escrita: pipeline RH (servidor) ou quem tiver bancoHoras.importar.
    match /bancoHoras/{funcionarioId} {
      allow read: if isAdmin() || isRH()
                  || (isLider() && resource.data.funcionarioTurno == userDoc().turno)
                  || isSupervisor();
      allow create, update, delete: if isAdmin() || temCap('bancoHoras.importar', isRH());
    }

    // ----- pj (controle de prestadores de serviço) -----
    // ver/editar/excluir controlados pela matriz (fallback = admin/RH de hoje).
    // Reajuste é um update do doc pj → coberto por pj.editar.
    match /pj/{id} {
      allow read: if isAdmin() || temCap('pj.ver', isRH());
      allow create, update: if isAdmin() || temCap('pj.editar', isRH());
      allow delete: if isAdmin() || temCap('pj.excluir', isRH());
    }

    // ----- auditoria (log global IMUTÁVEL) -----
    // Admin/quem tem auditoria.ver leem e criam; ninguém edita/apaga.
    match /auditoria/{id} {
      allow read: if isAdmin() || temCap('auditoria.ver', isRH());
      allow create: if (isAdmin() || temCap('auditoria.ver', isRH()))
        && request.resource.data.por == request.auth.uid
        && request.resource.data.acao is string
        && request.resource.data.acao.size() <= 200;
      allow update, delete: if false;
    }

    // ----- eventos (log de auditoria de TODO usuário · self-write append-only) -----
    // Cada usuário grava SÓ os PRÓPRIOS eventos (por == uid). Leitura só p/ auditoria.ver.
    // Append-only (sem update/delete). Destrava login de qualquer papel + ciência/leitura/assinatura
    // do colaborador numa fonte só, sem afrouxar /auditoria. Client-side/auto-relato: é histórico
    // interno, NÃO prova jurídica (anti-fraude server-side fica pra Cloud Function no futuro).
    // Campos limitados; 'alvo' neutro (quem chama não manda conteúdo sensível).
    match /eventos/{id} {
      allow read: if isAdmin() || temCap('auditoria.ver', isRH());
      allow create: if isAuthed()
        && request.resource.data.por == request.auth.uid
        && request.resource.data.em == request.time
        && request.resource.data.tipo is string
        && request.resource.data.tipo.size() <= 40
        && request.resource.data.acao is string
        && request.resource.data.acao.size() > 0
        && request.resource.data.acao.size() <= 200
        && request.resource.data.keys().hasOnly(['por', 'porNome', 'porRole', 'tipo', 'acao', 'alvo', 'em'])
        && (!('alvo' in request.resource.data) || (request.resource.data.alvo is string && request.resource.data.alvo.size() <= 300))
        && (!('porNome' in request.resource.data) || (request.resource.data.porNome is string && request.resource.data.porNome.size() <= 120))
        && (!('porRole' in request.resource.data) || (request.resource.data.porRole is string && request.resource.data.porRole.size() <= 40));
      allow update, delete: if false;
    }

    // ----- presence (quem está online agora) -----
    // So GESTOR escreve (o portal do colaborador nunca liga presenca, gate ehColab no
    // firebase.js) e o role gravado tem que ser o REAL do users/{uid} (antes validava so o
    // payload, entao qualquer autenticado se pintava de 'admin' no painel · Fable 2026-07-06).
    match /presence/{uid} {
      allow read: if isAuthed();
      allow create, update: if isAuthed() && request.auth.uid == uid
        && (isAdmin() || isRH() || isLider() || isSupervisor())
        && request.resource.data.role == userDoc().role
        && request.resource.data.nome is string
        && request.resource.data.nome.size() <= 100;
      allow delete: if isAuthed() && request.auth.uid == uid;
    }

    // ----- ocorrencias -----
    match /ocorrencias/{id} {
      allow read: if podeVerOcorrencia(resource.data)
        || (isColaborador() && euSouODono(resource.data.funcionarioId)); // colaborador vê só as próprias

      // Criar: quem tem ocorrencias.criar (fallback = RH de hoje) ou admin.
      allow create: if (isAdmin() || temCap('ocorrencias.criar', isRH()))
        && request.resource.data.criadoPor == request.auth.uid
        && request.resource.data.acao == null
        && request.resource.data.dataConferencia == null
        && request.resource.data.funcionarioId is string
        && request.resource.data.funcionarioTurno in [1, 2, 3, 'geral']
        && request.resource.data.tipo is string
        && request.resource.data.horario is string;

      // Update: admin sempre; RH lança/edita obs (cap ocorrencias.lancar);
      // líder/supervisor conferem no seu escopo (cap ocorrencias.conferir).
      // Fallbacks preservam exatamente o comportamento atual.
      allow update: if
        isAdmin()
        // GH edita observação SEMPRE (não depende do toggle de lançamento).
        || (isRH() && rhEditaObs())
        // GH marca/desfaz lançamento → gated pelo toggle ocorrencias.lancar.
        || (isRH() && temCap('ocorrencias.lancar', isRH()) && rhLanca())
        || (temCap('ocorrencias.conferir', isLider())
            && liderDoMesmoTurno(resource.data.funcionarioTurno)
            && podeConferirOuAtualizarObs())
        || (temCap('ocorrencias.conferir', isSupervisor())
            && isSupervisor()
            && (supervisorVe(resource.data.funcionarioId)
                || ('funcionarioTurno' in resource.data && supervisorVeTurno(resource.data.funcionarioTurno)))
            && podeConferirOuAtualizarObs())
        // Soft delete pra auditoria (2026-07-09): quem tem a cap de excluir MARCA a
        // flag (excluida/Em/Por) ou a LIMPA (restaurar). Estritamente menos poder que
        // o delete fisico abaixo, que segue permitido mas SAI do fluxo normal do app
        // (a exclusao da UI vira soft; o conteudo fica pra aba Excluidas).
        || ((isAdmin() || temCap('ocorrencias.excluir', isRH()))
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['excluida', 'excluidaEm', 'excluidaPor']));

      allow delete: if isAdmin() || temCap('ocorrencias.excluir', isRH());
    }

    // ----- banco-horas-saldos -----
    // Snapshot rico com CPF/PIS · SEMPRE só admin + RH (dado sensível, fixo).
    match /banco-horas-saldos/{funcId} {
      allow read: if isAdmin() || isRH();
      allow write: if false;
    }

    // ----- banco-horas -----
    match /banco-horas/{docId} {
      allow read: if isAdmin() || isRH();
      allow write: if false;
    }

    // ----- banco-horas-self (saldo + espelho SELF · SEM PII · doc por código) -----
    // Populado pelo pipeline (servidor). Colaborador lê SÓ o próprio (codigo == seu codigo);
    // admin/RH leem qualquer um. O GESTOR (Espelho de ponto do portal) lê os liderados:
    // líder pelo funcionarioTurno do doc, supervisor pelo funcionarioId do doc — ambos
    // DENORMALIZADOS no doc pelo pipeline. O guard 'campo in resource.data' fecha o buraco
    // do doc legado (sem o campo): nunca casa antes do pipeline gravar. string() coage o codigo.
    match /banco-horas-self/{codigo} {
      allow read: if isAdmin() || isRH()
                  || (isColaborador() && 'codigo' in userDoc() && string(userDoc().codigo) == codigo)
                  || (isLider() && 'funcionarioTurno' in resource.data && resource.data.funcionarioTurno == userDoc().turno)
                  || (isSupervisor() && 'funcionarioId' in resource.data && supervisorVe(resource.data.funcionarioId))
                  || (isSupervisor() && 'funcionarioTurno' in resource.data && supervisorVeTurno(resource.data.funcionarioTurno));
      allow write: if false;
    }

    // ----- recibos (recibo de pagamento / cartão ponto por funcionário · PDF no Storage) -----
    // METADADOS aqui; o PDF vive no Firebase Storage (recibos/{funcionarioId}/{competencia}.pdf).
    // Gerado pelo GP (import + quebra por CPF). Colaborador lê SÓ o dele (funcionarioId ==
    // meuFuncionarioId()); admin/RH gerenciam (cap recibos.gerenciar, fallback isRH). Campos de
    // origem (criadoEm/criadoPor/funcionarioId/competencia) imutáveis no update; delete só admin.
    // A assinatura N1 (Fase B) entrará numa subcoleção assinaturas/{uid} create-only (ainda não).
    match /recibos/{id} {
      allow read: if isAdmin() || temCap('recibos.gerenciar', isRH())
                  || (isColaborador() && resource.data.funcionarioId == meuFuncionarioId());

      allow create: if (isAdmin() || temCap('recibos.gerenciar', isRH()))
        && request.resource.data.criadoPor == request.auth.uid
        && request.resource.data.criadoEm == request.time
        && request.resource.data.funcionarioId is string
        && request.resource.data.competencia is string
        && request.resource.data.tipo is string;

      allow update: if (isAdmin() || temCap('recibos.gerenciar', isRH()))
        && request.resource.data.criadoEm == resource.data.criadoEm
        && request.resource.data.criadoPor == resource.data.criadoPor
        && request.resource.data.funcionarioId == resource.data.funcionarioId
        && request.resource.data.competencia == resource.data.competencia;

      allow delete: if isAdmin();

      // arquivo/{docId}: o PDF (base64) mora AQUI, separado dos metadados — a lista do
      // gestor lê só o pai (leve) e o arquivo é buscado sob demanda ao abrir. funcionarioId
      // DENORMALIZADO no subdoc (evita get() no pai a cada LEITURA). No CREATE, o subdoc é
      // AMARRADO ao pai: precisa existir (existsAfter cobre o batch pai+filho junto) e o
      // funcionarioId tem que bater com o do pai — sem arquivo órfão nem trocado. Payload
      // fechado (hasOnly). Imutável: substituição = admin exclui o lote e o GP reimporta.
      // delete só admin é DECISÃO (espelha documentos): RH gerencia create/update; destruir, não.
      match /arquivo/{docId} {
        allow read: if isAdmin() || temCap('recibos.gerenciar', isRH())
                    || (isColaborador() && resource.data.funcionarioId == meuFuncionarioId());
        allow create: if (isAdmin() || temCap('recibos.gerenciar', isRH()))
                      && request.resource.data.keys().hasOnly(['funcionarioId', 'base64'])
                      && request.resource.data.funcionarioId is string
                      && existsAfter(/databases/$(database)/documents/recibos/$(id))
                      && request.resource.data.funcionarioId
                           == getAfter(/databases/$(database)/documents/recibos/$(id)).data.funcionarioId;
        allow update: if false;
        allow delete: if isAdmin();
      }

      // assinaturas/{uid}: a trilha da Fase B — create-only pelo DONO do recibo, com
      // geolocalização EXIGIDA (decisão do William: sem local, não assina). Campos
      // fechados; funcionarioId tem que bater com o do recibo pai (get); em = hora do
      // servidor. Reassinar não existe: update/delete negados (2º set vira update => nega).
      // Gestor NÃO assina pelo colaborador. arquivoPath aponta a versão carimbada no Storage.
      match /assinaturas/{uid} {
        allow read: if isAdmin() || temCap('recibos.gerenciar', isRH())
                    || (isAuthed() && request.auth.uid == uid);
        allow create: if isColaborador()
          && request.auth.uid == uid
          && request.resource.data.uid == uid
          && request.resource.data.keys().hasOnly(['uid', 'funcionarioId', 'em', 'userAgent', 'geo', 'hashSha256', 'aceiteTexto', 'arquivoPath'])
          && request.resource.data.em == request.time
          && request.resource.data.geo.lat is number
          && request.resource.data.geo.lng is number
          && euSouODono(request.resource.data.funcionarioId)
          && request.resource.data.funcionarioId
               == get(/databases/$(database)/documents/recibos/$(id)).data.funcionarioId;
        allow update, delete: if false;
      }
    }

    // ----- pipeline-rh (estrutura cur/hist · espelho do Comercial · SEM PII) -----
    match /pipeline-rh/{docId} {
      allow read: if isAdmin() || isRH();
      allow write: if false;
    }

    // ----- identificacao (diretório código→{nome, cpf} de TODOS os ativos · PII) -----
    // Fonte do casamento CPF→funcionário no import de recibos: cobre quem NÃO tem banco
    // de horas (ex.: menor aprendiz, que nunca entra em banco-horas-saldos). Populada
    // pelo pipeline (WKRADAR, Admin SDK). Leitura só admin/RH (LGPD); ninguém escreve
    // pelo cliente. O CPF daqui NUNCA persiste nos docs do colaborador.
    match /identificacao/{codigo} {
      allow read: if isAdmin() || isRH();
      allow write: if false;
    }

    // ===== Pacote Gestor (ADITIVO) — Comunicados + Documentos institucionais =====

    // ----- comunicados (canal oficial 1→N originado no gestor) -----
    // Leitura: gestor com a cap vê todos; colaborador vê só ativos do seu segmento.
    // Escrita: gated por comunicados.gerenciar (fallback RH). publicadoEm é server-time
    // no create e imutável no update; autorUid imutável. Soft-delete (ativo=false) é o
    // caminho normal; delete físico só admin.
    match /comunicados/{id} {
      allow read: if isAdmin() || temCap('comunicados.gerenciar', isRH())
                  || (isColaborador()
                      && resource.data.ativo == true
                      && casaSegmento(resource.data.segmento));

      allow create: if (isAdmin() || temCap('comunicados.gerenciar', isRH()))
                    && request.resource.data.autorUid == request.auth.uid
                    && request.resource.data.publicadoEm == request.time
                    && request.resource.data.ativo is bool;

      allow update: if (isAdmin() || temCap('comunicados.gerenciar', isRH()))
                    && request.resource.data.publicadoEm == resource.data.publicadoEm
                    && request.resource.data.autorUid == resource.data.autorUid;

      allow delete: if isAdmin();

      // leituras/{uid}: 1 por pessoa (self-write), amarrada ao segmento do pai
      // (não infla X/Y com quem não vê o doc). Append-only.
      match /leituras/{uid} {
        allow read: if isAdmin() || temCap('comunicados.gerenciar', isRH())
                    || (isAuthed() && request.auth.uid == uid);
        allow create: if isAuthed()
                    && request.auth.uid == uid
                    && request.resource.data.uid == uid
                    && request.resource.data.keys().hasOnly(['uid', 'funcionarioId', 'confirmado', 'em', 'userAgent'])
                    && (isAdmin() || temCap('comunicados.gerenciar', isRH())
                        || casaSegmento(get(/databases/$(database)/documents/comunicados/$(id)).data.segmento));
        allow update, delete: if false;
      }
    }

    // ----- documentos (institucional por segmento + pessoal por dono coexistindo) -----
    // institucional = sem funcionarioId, com segmento; pessoal = com funcionarioId, sem segmento.
    // criadoEm/criadoPor/escopo imutáveis. Em doc publicado+exigeAssinatura, segmento/anexo
    // imutáveis por update direto (CORREÇÃO 4): a ÚNICA forma de trocar anexo é novaVersao
    // (versao incrementa em 1). Subcoleções amarradas ao pai; versaoAssinada == versao atual.
    //
    // NÍVEL DE CONFIRMAÇÃO (ADITIVO): campo `confirmacao` em ['nenhuma','aceite','assinatura'].
    // O legado (exigeAssinatura, sem confirmacao) segue valendo: nível efetivo derivado só
    // pela UI/backend; a rule apenas RESTRINGE o valor de confirmacao quando presente e trava
    // que o colaborador o altere (não pode escrever no doc pai de qualquer forma). Só quem já
    // pode criar/editar documentos grava confirmacao (mesma condição gated do match).
    match /documentos/{id} {
      allow read: if isAdmin() || temCap('documentos.gerenciar', isRH())
        || (isColaborador() && resource.data.status == 'publicado' && (
             (resource.data.escopo == 'institucional' && casaSegmento(resource.data.segmento))
             || (resource.data.escopo == 'pessoal' && resource.data.funcionarioId == meuFuncionarioId())
           ));

      allow create: if (isAdmin() || temCap('documentos.gerenciar', isRH()))
        && request.resource.data.criadoPor == request.auth.uid
        && request.resource.data.criadoEm == request.time
        && (!('confirmacao' in request.resource.data)
            || request.resource.data.confirmacao in ['nenhuma', 'aceite', 'assinatura'])
        && (
          (request.resource.data.escopo == 'institucional'
            && !('funcionarioId' in request.resource.data))
          || (request.resource.data.escopo == 'pessoal'
            && request.resource.data.funcionarioId is string)
        );

      allow update: if (isAdmin() || temCap('documentos.gerenciar', isRH()))
        && request.resource.data.criadoEm == resource.data.criadoEm
        && request.resource.data.criadoPor == resource.data.criadoPor
        && request.resource.data.escopo == resource.data.escopo
        && (!('confirmacao' in request.resource.data)
            || request.resource.data.confirmacao in ['nenhuma', 'aceite', 'assinatura'])
        && (
          // só trava quando já publicado E exige assinatura; senão update livre (gated)
          !(resource.data.status == 'publicado' && resource.data.exigeAssinatura == true)
          || (
            request.resource.data.segmento == resource.data.segmento
            && (
              // anexo imutável, EXCETO quando é uma novaVersao (versao incrementa em 1)
              request.resource.data.anexo == resource.data.anexo
              || request.resource.data.versao == resource.data.versao + 1
            )
          )
        );

      allow delete: if isAdmin();

      // aceites/{uid}: NÍVEL 'aceite' — o "Li e aceito" simples (sem senha/local/carimbo).
      // Create-only pelo colaborador DONO (uid == auth.uid). Payload mínimo e fechado;
      // em == hora do servidor; amarrado ao segmento/dono do pai. Append-only (imutável).
      // Separado de 'assinaturas' de propósito: aqui NÃO há geo nem hash de arquivo.
      match /aceites/{uid} {
        allow read: if isAdmin() || temCap('documentos.gerenciar', isRH())
                    || (isAuthed() && request.auth.uid == uid);
        allow create: if isAuthed()
                    && request.auth.uid == uid
                    && request.resource.data.uid == uid
                    && request.resource.data.keys().hasOnly(['uid', 'em', 'userAgent', 'versao'])
                    && request.resource.data.em == request.time
                    && (isAdmin() || temCap('documentos.gerenciar', isRH())
                        || podeVerDoc(get(/databases/$(database)/documents/documentos/$(id)).data));
        allow update, delete: if false;
      }

      // assinaturas/{uid}: create-only pelo DONO, versaoAssinada == versao atual do pai
      // (CORREÇÃO 7); amarrada ao segmento/dono do pai (CORREÇÃO 6). DUAS formas aceitas
      // (aditivo, retrocompatível):
      //  (a) LEGADO N1: uid/funcionarioId/versaoAssinada/hashSha256/aceiteTexto/em/userAgent
      //      — o "Li e aceito" com hash do anexo, SEM geo (fluxo já no ar).
      //  (b) NÍVEL 'assinatura' CARIMBADO (espelha recibos): + geo.lat/lng number e
      //      arquivoPath — senha+localização+carimbo no arquivo. em == hora do servidor.
      // Em ambas: em == request.time, versaoAssinada number == versao do pai. Append-only.
      match /assinaturas/{uid} {
        allow read: if isAdmin() || temCap('documentos.gerenciar', isRH())
                    || (isAuthed() && request.auth.uid == uid);
        allow create: if isAuthed()
                    && request.auth.uid == uid
                    && request.resource.data.uid == uid
                    && request.resource.data.em == request.time
                    && request.resource.data.versaoAssinada is number
                    && request.resource.data.versaoAssinada
                         == get(/databases/$(database)/documents/documentos/$(id)).data.versao
                    && (
                      // (a) legado N1 (sem geo)
                      request.resource.data.keys().hasOnly(['uid', 'funcionarioId', 'versaoAssinada', 'hashSha256', 'aceiteTexto', 'em', 'userAgent'])
                      // (b) carimbo com geo (espelha recibos)
                      || (
                        request.resource.data.keys().hasOnly(['uid', 'funcionarioId', 'versaoAssinada', 'hashSha256', 'aceiteTexto', 'em', 'userAgent', 'geo', 'arquivoPath'])
                        && request.resource.data.geo.lat is number
                        && request.resource.data.geo.lng is number
                        && request.resource.data.arquivoPath is string
                      )
                    )
                    && (isAdmin() || temCap('documentos.gerenciar', isRH())
                        || podeVerDoc(get(/databases/$(database)/documents/documentos/$(id)).data));
        allow update, delete: if false;
      }

      // leituras/{uid}: visualização sem assinatura (docs exigeAssinatura=false). Append-only.
      match /leituras/{uid} {
        allow read: if isAdmin() || temCap('documentos.gerenciar', isRH())
                    || (isAuthed() && request.auth.uid == uid);
        allow create: if isAuthed() && request.auth.uid == uid
                    && request.resource.data.uid == uid
                    && request.resource.data.keys().hasOnly(['uid', 'funcionarioId', 'confirmado', 'em', 'userAgent'])
                    && (isAdmin() || temCap('documentos.gerenciar', isRH())
                        || podeVerDoc(get(/databases/$(database)/documents/documentos/$(id)).data));
        allow update, delete: if false;
      }
    }

    // ===== Termo de adesao a assinatura eletronica (ciencia no 1o acesso) =====
    // Um registro por pessoa (id = uid), IMUTAVEL: a ciencia do termo de adesao ao meio
    // eletronico, dada no primeiro acesso (depois de criar a senha). O app so mostra o
    // termo se este doc NAO existir. Ler: o proprio dono E o gestor (auditoria/LGPD).
    // ponytail: se o termo mudar de versao um dia, migrar pra id {uid}__{versao} pra
    // permitir readesao; hoje e create-only por id fixo (uma ciencia por pessoa).
    match /termoAdesao/{uid} {
      allow read: if isAuthed() && (request.auth.uid == uid || isAdmin() || temCap('documentos.gerenciar', isRH()));
      allow create: if isAuthed()
                  && request.auth.uid == uid
                  && request.resource.data.uid == uid
                  && request.resource.data.keys().hasOnly(['uid', 'funcionarioId', 'versao', 'hashSha256', 'em', 'userAgent'])
                  && euSouODono(request.resource.data.funcionarioId)
                  && request.resource.data.versao == '2026-07-v1'
                  && request.resource.data.hashSha256 == '931a476238918cb6e771e30238b307403606b224b1b32745ce21f6197e16c805'
                  && request.resource.data.userAgent is string
                  && request.resource.data.em == request.time;
      allow update, delete: if false;
    }
    // versao + hashSha256 CRAVADOS na regra (Fable): a versao e o sha256 do texto canonico
    // congelado (docs/termo-adesao-2026-07-v1.txt, LF) ancoram QUAL texto foi aceito, fora do
    // controle unilateral da empresa. Bump de versao = novo hash aqui + readesao.

    // ===== Termo do canal de denuncias (peca final da trilogia · ciencia no 1o acesso) =====
    // ESPELHO EXATO do termoAdesao acima: um registro por pessoa (id = uid), IMUTAVEL, dado no
    // primeiro acesso DEPOIS da adesao (o app so mostra o gate se este doc NAO existir). Vive no
    // 1o acesso de proposito: se o aceite morasse na porta do canal de denuncia, a data da
    // assinatura entregaria quem usou o canal (Lei 14.457/2022); no 1o acesso todo mundo aceita
    // no mesmo momento e nada correlaciona a assinatura ao uso. Ler: o proprio dono E o gestor.
    match /termoCanalDenuncia/{uid} {
      allow read: if isAuthed() && (request.auth.uid == uid || isAdmin() || temCap('documentos.gerenciar', isRH()));
      allow create: if isAuthed()
                  && request.auth.uid == uid
                  && request.resource.data.uid == uid
                  && request.resource.data.keys().hasOnly(['uid', 'funcionarioId', 'versao', 'hashSha256', 'em', 'userAgent'])
                  && euSouODono(request.resource.data.funcionarioId)
                  && request.resource.data.versao == '2026-07-v1'
                  && request.resource.data.hashSha256 == 'f7bf0960ff6e24f20800b414ed3d354e0e0291417996842a552984b87dbc830a'
                  && request.resource.data.userAgent is string
                  && request.resource.data.em == request.time;
      allow update, delete: if false;
    }
    // versao + hashSha256 CRAVADOS (docs/termo-canal-denuncia-2026-07-v1.txt, LF), mesma ancora
    // do adesao. Bump de versao = novo hash aqui + reaceite.

    // ===== Mural de aniversario (celebracao social entre colegas) =====
    // postId "aniv-{slug}-{ano}" (aniversario), "bv-{slug}-{anoAdmissao}" (boas-vindas
    // a recem-contratados, 2026-07-09) OU "tdc-{slug}-{anoCorrente}" (tempo de casa,
    // 2026-07-17; shape confirmado pelo pipeline). Mesmo sistema de reacao. NAO exige
    // doc pai (subcolecoes valem sem ele); por isso o proprio /muralAniversario/{postId}
    // nunca e escrito pelo cliente.
    // Conteudo entre colegas: reacao (coracao no aniversario, bemvindo no bv-; uma por
    // pessoa, toggle) e recado (texto curto, varios por pessoa). Leitura: qualquer
    // autenticado (a festa e compartilhada).
    // Escrita: so como voce mesmo (autorUid/uid == auth.uid). Recado apaga o proprio autor
    // OU gestor (moderacao/LGPD); o autorUid fica gravado como trilha de quem escreveu.
    // Recado append-only; reacao aceita re-set idempotente (mesmo conteudo, anti-spoof
    // intacto) pra 2a tentativa nao virar erro. em == hora do servidor.
    match /muralAniversario/{postId} {
      allow read: if isAuthed();
      allow write: if false; // doc pai nunca e escrito pelo cliente

      match /reacoes/{uid} {
        // Mesma predicado pro create E pro update: reagir de novo com o MESMO
        // conteudo e idempotente (nao erro). Sem isso, o cliente que refaz o
        // set() num doc que ja existe (2a tentativa apos leitura stale em rede
        // ruim) caia em update -> negado -> toast. A igualdade anti-spoof
        // (autorNome == userDoc().nome) segue intacta.
        // Tipo casado com o prefixo do post (disjuncao explicita, padrao da casa):
        // post bv- so aceita 'bemvindo'; aniversario E tempo de casa (tdc-) aceitam
        // 'coracao' (mesmo gesto na UI; quem distingue o credito e o provaOk, que
        // le o tipo do PAI, nao o da reacao).
        // Guard de auto-toque (nao reagir ao proprio post) fica no CLIENTE: o postId
        // chaveia por slug do nome e a regra nao slugifica; o risco residual e so
        // cosmetico (contador do proprio card), sem PII nem perda de dado.
        // ponytail: guard server-side exigiria funcionarioId no postId ou doc pai
        // escrito pelo servidor.
        function reacaoOk() {
          return isAuthed()
              && request.auth.uid == uid
              && request.resource.data.uid == uid
              && request.resource.data.keys().hasOnly(['uid', 'tipo', 'autorNome', 'em'])
              && ((postId.matches('bv-.*') && request.resource.data.tipo == 'bemvindo')
               || (!postId.matches('bv-.*') && request.resource.data.tipo == 'coracao'))
              && request.resource.data.autorNome is string
              && request.resource.data.autorNome.size() <= 80
              && request.resource.data.autorNome == userDoc().nome
              && request.resource.data.em == request.time;
        }
        allow read: if isAuthed();
        allow create: if reacaoOk();
        allow update: if reacaoOk();
        allow delete: if isAuthed() && (request.auth.uid == uid || isAdmin() || isRH());
      }

      match /recados/{recadoId} {
        allow read: if isAuthed();
        allow create: if isAuthed()
                    && request.resource.data.autorUid == request.auth.uid
                    && request.resource.data.keys().hasOnly(['autorUid', 'autorNome', 'texto', 'em'])
                    && request.resource.data.autorNome is string
                    && request.resource.data.autorNome.size() <= 80
                    && request.resource.data.autorNome == userDoc().nome
                    && request.resource.data.texto is string
                    && request.resource.data.texto.size() >= 1
                    && request.resource.data.texto.size() <= 500
                    && request.resource.data.em == request.time;
        allow delete: if isAuthed()
                    && (resource.data.autorUid == request.auth.uid || isAdmin() || isRH());
        allow update: if false;
      }
    }

    // ===== ocorrencias-auto (TESTE / sandbox) =====
    // Ocorrências geradas pelo pipeline da apuração do ponto (WK). Coleção SEPARADA da
    // 'ocorrencias' de produção: zero impacto no fluxo manual. O CONTEÚDO é escrito só pelo
    // servidor (Admin SDK, que ignora estas rules). Do app, admin/RH apenas LÊ e CONFERE:
    // muda status -> 'conferida' e faz APPEND no historico (quem/quando). Sem PII na coleção.
    // Modelo cria-e-nunca-reabre: o cliente só leva status PARA 'conferida', nunca de volta.
    // Fluxo de 2 estagios (RH -> Lider): pipeline cria 'rh_confere'; RH valida (-> 'com_lider')
    // ou dispensa (-> 'dispensada'); lider do TURNO confirma (-> 'confirmada'). Cria-e-nunca-reabre
    // (status novo nunca volta pra 'rh_confere'). Legado: 'aguardando_conferencia' (= RH confere) e
    // 'conferida' (terminal antigo) seguem aceitos durante a transicao.
    match /ocorrencias-auto/{id} {
      // READ amplo pro supervisor (espelha /ocorrencias: podeVerOcorrencia da read amplo ao
      // supervisor e a UI filtra pelo escopo dele na INGESTAO). Sem PII forte nesta colecao;
      // os 4 supervisores ja leem todas as manuais via API. Escopo estrito (supervisorVe/
      // VeTurno) fica no WRITE abaixo. ponytail: se um dia precisar estrito no read, e 1 query
      // == por turno + in chunked de 30 pros funcionariosVisiveis, com merge no cliente.
      allow read: if isAdmin() || isRH()
                  || (isLider() && resource.data.turno == userDoc().turno)
                  || isSupervisor();

      // acao/observacao: a DESTINAÇÃO que o líder escolhe ao conferir (mesma liturgia
      // da ocorrência manual — pedido do William 2026-07-02). Continuam gated pelas
      // mesmas transições de status abaixo.
      // O lock de campos (hasOnly) vive DENTRO de cada ramo: o RH/admin pode CORRIGIR
      // 'tipo' e 'duracaoFmt' junto da transicao (nunca deixa em rh_confere, onde o
      // pipeline reprocessaria e reverteria a correcao); o lider NAO reclassifica, so
      // confirma, entao seu ramo segue travado nos 4 campos originais.
      // 'is list' primeiro (guarda Fable 2026-07-06): sem ele, uma STRING/MAP com size()
      // == +1 passaria e a trilha inteira viraria lixo (perda de dado irreversivel).
      allow update: if request.resource.data.historico is list
        && request.resource.data.historico.size() == resource.data.historico.size() + 1
        && (
          // RH/admin no estagio "RH confere": manda pro lider, dispensa, ou conclui direto.
          // Pode corrigir tipo/duracaoFmt no mesmo update (a transicao tira de rh_confere).
          ( (isAdmin() || temCap('ocorrencias.revisarAuto', isRH()))
            && resource.data.status in ['rh_confere', 'aguardando_conferencia', 'com_lider']
            && request.resource.data.status in ['com_lider', 'dispensada', 'confirmada', 'conferida']
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'historico', 'acao', 'observacao', 'tipo', 'duracaoFmt', 'classificacaoIncerta'])
            // Se a correcao TOCOU o campo, ele tem que continuar string plausivel: barra o
            // delete (o WK nao repoe fora de rh_confere -> seria perda de dado irreversivel)
            // e valor nao-string. Quem nao toca o campo passa igual (aditivo, inclui legado).
            && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['tipo'])
                || (request.resource.data.tipo is string
                    && request.resource.data.tipo.size() >= 1
                    && request.resource.data.tipo.size() <= 80))
            && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['duracaoFmt'])
                || (request.resource.data.duracaoFmt is string
                    && request.resource.data.duracaoFmt.size() >= 1
                    && request.resource.data.duracaoFmt.size() <= 20))
            // A revisao da RH SO PODE ZERAR a incerteza (nunca re-flaga): se tocar o campo,
            // tem que ser == false. "incerto" e afirmacao sobre o estado atual (precisa de
            // humano?); depois que a RH revisou, e nao. motivoIncerteza/historico ficam.
            && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['classificacaoIncerta'])
                || request.resource.data.classificacaoIncerta == false) )
          ||
          // Lider do TURNO confirma o que esta "com o lider" — sem tocar na classificacao.
          ( isLider() && resource.data.turno == userDoc().turno
            && resource.data.status == 'com_lider'
            && request.resource.data.status == 'confirmada'
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'historico', 'acao', 'observacao']) )
          ||
          // Supervisor confirma no ESCOPO (avulsos OU turno) — paridade com o conferir da
          // ocorrencia manual (William 2026-07-08); mesma transicao e mesmos campos do lider.
          ( temCap('ocorrencias.conferir', isSupervisor())
            && isSupervisor()
            && (('funcionarioId' in resource.data && supervisorVe(resource.data.funcionarioId))
                || ('turno' in resource.data && supervisorVeTurno(resource.data.turno)))
            && resource.data.status == 'com_lider'
            && request.resource.data.status == 'confirmada'
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'historico', 'acao', 'observacao']) )
          ||
          // RH/admin LANCA na folha (ou desfaz) uma ja decidida — espelho do fluxo manual
          // (mesma cap ocorrencias.lancar; pedido William 2026-07-08). NAO mexe no status
          // (fora do hasOnly); marcar exige o trio coerente, desfazer zera o trio.
          ( (isAdmin() || temCap('ocorrencias.lancar', isRH()))
            && resource.data.status in ['confirmada', 'conferida']
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lancada', 'lancadoEm', 'lancadoPor', 'historico'])
            && (
              (request.resource.data.lancada == true
                && request.resource.data.lancadoEm is string
                && request.resource.data.lancadoPor == request.auth.uid)
              ||
              (request.resource.data.lancada == false
                && request.resource.data.lancadoEm == null
                && request.resource.data.lancadoPor == null)
            ) )
        );

      // Conteúdo nasce e some só pelo servidor (Admin SDK bypassa rules).
      allow create, delete: if false;
    }

    // ===== monitor/wkradar — saúde do pipeline RH (somente leitura no app) =====
    // Doc gravado pelo servidor (Admin SDK) a cada execução do pipeline. SEM PII (só nomes
    // de arquivo/coleção, horários, contagens). Admin/RH leem; o app nunca escreve.
    match /monitor/{doc} {
      allow read: if isAdmin() || temCap('pipeline.monitor', isRH());
      allow write: if false;
    }

    // ===== disciplinares (advertencia/suspensao) — registro disciplinar SENSIVEL =====
    // Registra: admin/RH. Le: admin/RH, lider do TURNO do funcionario, e o PROPRIO
    // colaborador (so a dele, via funcionarioId). Tem anexo (doc) + ciencia do colaborador
    // (subcolecao self-write, append-only). Delete so admin. Auditoria em /auditoria (create).
    match /disciplinares/{id} {
      allow read: if isAdmin() || isRH()
        || liderDoMesmoTurno(resource.data.funcionarioTurno)
        || (isColaborador() && resource.data.funcionarioId == meuFuncionarioId());

      allow create: if (isAdmin() || isRH())
        && request.resource.data.aplicadoPor == request.auth.uid
        && request.resource.data.criadoEm == request.time
        && request.resource.data.funcionarioId is string
        && request.resource.data.funcionarioId.size() > 0
        && request.resource.data.tipo in ['verbal', 'escrita', 'suspensao'];

      // Edicao restrita (correcao de motivo/descricao/anexo/dias/data) por admin/RH;
      // funcionario/tipo/aplicadoPor/criadoEm sao imutaveis.
      allow update: if (isAdmin() || isRH())
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['motivo', 'descricao', 'anexo', 'dias', 'data', 'editadoEm', 'editadoPor']);

      allow delete: if isAdmin();

      // ciencia/{uid}: o colaborador DONO confirma que leu. Append-only, self-write,
      // amarrada ao dono do registro pai (funcionarioId == meuFuncionarioId).
      match /ciencia/{uid} {
        allow read: if isAdmin() || isRH()
          || liderDoMesmoTurno(get(/databases/$(database)/documents/disciplinares/$(id)).data.funcionarioTurno)
          || (isAuthed() && request.auth.uid == uid);
        allow create: if isAuthed()
          && request.auth.uid == uid
          && request.resource.data.uid == uid
          && request.resource.data.keys().hasOnly(['uid', 'funcionarioId', 'em', 'userAgent'])
          && get(/databases/$(database)/documents/disciplinares/$(id)).data.funcionarioId == meuFuncionarioId();
        allow update, delete: if false;
      }
    }

    // ----- Helpers de atualização -----

    // GH editando só a observação (anotação benigna) — sempre permitido,
    // independe do toggle de lançamento.
    function rhEditaObs() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['observacao', 'historico', 'atualizadoEm']);
    }
    // GH mexendo no status de lançamento — gated pela capability ocorrencias.lancar.
    function rhLanca() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['lancada', 'lancadoEm', 'lancadoPor', 'historico', 'atualizadoEm']);
    }

    function podeConferirOuAtualizarObs() {
      let allowedKeys = ['observacao', 'historico', 'atualizadoEm',
                         'acao', 'dataConferencia', 'conferidoPor'];
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      let mudancasPermitidas = changed.hasOnly(allowedKeys);
      let acaoOk = !changed.hasAny(['acao']) || resource.data.acao == null;
      let dataOk = !changed.hasAny(['dataConferencia']) || resource.data.dataConferencia == null;
      return mudancasPermitidas && acaoOk && dataOk;
    }

    // ============================================================
    // PESQUISA DE CLIMA (2026-07-09) -- anonimato CONFIGURAVEL por pesquisa.
    // Desenho + gate: conselheiro-fable. Anonimato ESTRUTURAL, nao filtro de UI: a
    // resposta anonima e doc ORFAO (sem uid e SEM campo de tempo; ate o createTime
    // via REST e risco, por isso o gestor NUNCA le recibos e so le as cruas
    // depois de ENCERRADA + k>=5). Sem Cloud Functions -> agregacao client-side
    // sobre as cruas depois de encerrada. Cap nova pesquisas.gerenciar e GLOBAL
    // (temCap sem escopo): NUNCA conceder 'turno'/'atrib' pra ela. Residuais
    // (createTime x /eventos, conluio ativo, k de grupo pequeno) em
    // docs/HISTORICO-DECISOES.md. ponytail: scrub de metadado (WK noturno) ou
    // Cloud Function se um dia precisar fechar o residual.
    // ============================================================
    match /pesquisasClima/{pid} {
      function gpClima() { return isAdmin() || temCap('pesquisas.gerenciar', isRH()); }
      function pai() { return get(/databases/$(database)/documents/pesquisasClima/$(pid)).data; }
      function meuReciboNasceuAgora() {
        return !exists(/databases/$(database)/documents/pesquisasClima/$(pid)/recibos/$(request.auth.uid))
            && existsAfter(/databases/$(database)/documents/pesquisasClima/$(pid)/recibos/$(request.auth.uid));
      }

      // Config: gestor le tudo; colaborador le SO as abertas que casam o publico (a
      // query do cliente filtra igual, senao a regra de list nega).
      allow read: if gpClima()
                  || (isAuthed() && resource.data.status == 'aberta' && casaSegmento(resource.data.publico));
      allow create: if gpClima()
        && request.resource.data.criadoPor == request.auth.uid
        && request.resource.data.criadoEm == request.time
        && request.resource.data.status == 'rascunho'
        && request.resource.data.titulo is string
        && request.resource.data.titulo.size() >= 1 && request.resource.data.titulo.size() <= 120
        && request.resource.data.anonima is bool
        && request.resource.data.incluiEnps is bool
        && request.resource.data.incluiAberta is bool
        && request.resource.data.dimensoes is list && request.resource.data.dimensoes.size() <= 12
        && request.resource.data.publico.tipo in ['todos', 'turno', 'setor']
        && request.resource.data.publico.valores is list;
      // 3 ramos: (1) editar rascunho ou ABRIR (cria contador no mesmo batch);
      // (2) aberta, so estender a janela (fim); (3) aberta -> encerrada (one-way).
      // O hasOnly por ramo congela anonima/dimensoes/publico/titulo apos aberta;
      // encerrada nao tem ramo (imutavel). One-way do status e seguranca: sem ele o
      // gestor encerra, le e reabre pra ver as respostas chegando uma a uma.
      allow update: if gpClima() && (
        ( resource.data.status == 'rascunho'
          && request.resource.data.criadoPor == resource.data.criadoPor
          && request.resource.data.criadoEm == resource.data.criadoEm
          && request.resource.data.anonima is bool
          && request.resource.data.status in ['rascunho', 'aberta']
          && ( request.resource.data.status == 'rascunho'
               || ( existsAfter(/databases/$(database)/documents/pesquisasClima/$(pid)/meta/contador)
                    && request.resource.data.abertaEm == request.time
                    && request.resource.data.abertaPor == request.auth.uid ) ) )
        ||
        ( resource.data.status == 'aberta'
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['fim']) )
        ||
        ( resource.data.status == 'aberta'
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'encerradaEm', 'encerradaPor'])
          && request.resource.data.status == 'encerrada'
          && request.resource.data.encerradaEm == request.time
          && request.resource.data.encerradaPor == request.auth.uid )
      );
      allow delete: if isAdmin() || (gpClima() && resource.data.status == 'rascunho');

      // Contador (so o total; NAO e agregado). Gestor le o progresso; o respondente
      // incrementa +1 UMA vez, no batch em que o SEU recibo nasce. Gestor sem update
      // (senao inflava n e destravava o k). increment(1) do SDK avalia o valor final.
      match /meta/contador {
        allow read: if gpClima();
        allow create: if gpClima()
          && request.resource.data.keys().hasOnly(['n']) && request.resource.data.n == 0;
        allow update: if isAuthed()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['n'])
          && request.resource.data.n == resource.data.n + 1
          && meuReciboNasceuAgora();
        allow delete: if false;
      }

      // Recibo: SO marca que aquele uid entregou (dedup + "voce ja respondeu" +
      // veiculo da elegibilidade). Zero conteudo. SELF-ONLY: o gestor NUNCA le (o
      // createTime do recibo entregaria o horario -> correlacao com a resposta).
      match /recibos/{uid} {
        function podeCriarRecibo() {
          let p = pai();
          return isAuthed() && request.auth.uid == uid
            && request.resource.data.keys().hasOnly(['em'])
            && request.resource.data.em == request.time
            && p.status == 'aberta'
            && ( !('fim' in p) || request.time < p.fim )
            && casaSegmento(p.publico);
        }
        allow read: if isAuthed() && request.auth.uid == uid;
        allow create: if podeCriarRecibo();
        allow update, delete: if false;
      }

      // Respostas. Anonima: rid = auto-id, payload SEM identidade e SEM tempo; a
      // elegibilidade e provada pelo recibo que nasce no MESMO batch (nao precisa de
      // uid no doc). Gestor le anonima SO encerrada + n>=5 (k CRAVADO na regra).
      // Imutavel (responder e ato unico, mesma liturgia de assinaturas).
      match /respostas/{rid} {
        function conteudoOk() {
          return request.resource.data.notas is map
            && request.resource.data.notas.size() >= 1 && request.resource.data.notas.size() <= 40
            && ( !('enps' in request.resource.data)
                 || (request.resource.data.enps is int
                     && request.resource.data.enps >= 0 && request.resource.data.enps <= 10) )
            && ( !('comentario' in request.resource.data)
                 || (request.resource.data.comentario is string
                     && request.resource.data.comentario.size() <= 1000) );
        }
        function podeCriar() {
          let p = pai();
          // Disjuncao EXPLICITA (nao ternario): lixo em 'anonima' (string/null/num) tem que
          // NEGAR, nao cair num default. anonima e o campo do gate de LGPD (ressalva Fable).
          return isAuthed() && p.status == 'aberta' && meuReciboNasceuAgora() && conteudoOk()
            && ( ( p.anonima == true
                   && rid != request.auth.uid
                   && request.resource.data.keys().hasOnly(['notas', 'enps', 'comentario']) )
                 || ( p.anonima == false
                      && rid == request.auth.uid
                      && request.resource.data.uid == request.auth.uid
                      && request.resource.data.respondidoEm == request.time
                      && request.resource.data.keys().hasOnly(['uid', 'notas', 'enps', 'comentario', 'respondidoEm']) ) );
        }
        function podeLer() {
          let p = pai();
          return ( gpClima()
                   && ( p.anonima == false
                        || ( p.status == 'encerrada'
                             && get(/databases/$(database)/documents/pesquisasClima/$(pid)/meta/contador).data.n >= 5 ) ) )
                 || ( p.anonima == false && isAuthed() && request.auth.uid == rid );
        }
        allow read: if podeLer();
        allow create: if podeCriar();
        allow update, delete: if false;
      }
    }

    // ============================================================
    // AVALIACAO DE DESEMPENHO (feature 2 das Avaliacoes, 2026-07-09).
    // v1 = modalidades 'gestor' (so o gestor avalia) e 'auto' (gestor +
    // autoavaliacao lado a lado); o '360' de pares anonimos FICA FORA ate
    // existir Cloud Functions (sorteio/agregacao server-side; decisao do
    // William). RH/admin cria os ciclos (cap desempenho.gerenciar, GLOBAL:
    // NUNCA conceder 'turno'/'atrib'); o gestor avalia SO alvos do proprio
    // escopo (lider por turno, supervisor por lista/turnos, validado NA REGRA
    // via users/{alvoUid} denormalizado, mesmos campos do casaSegmento); o
    // colaborador faz a autoavaliacao e le o que e sobre si SO concluido.
    // Sem PII denormalizada no doc (identidade via funcionarios no runtime).
    // Gaps gestor x auto calculados no cliente; por isso NAO ha colecao
    // 'resultados' no v1 (ela e do 360 server-side).
    // ============================================================
    match /avaliacaoCiclos/{cicloId} {
      function gpDesemp() { return isAdmin() || temCap('desempenho.gerenciar', isRH()); }
      function ciclo() { return get(/databases/$(database)/documents/avaliacaoCiclos/$(cicloId)).data; }
      // O ALVO e chaveado por funcionarioId (nao uid de users): o gestor opera por
      // state.funcionarios e nao conhece uids; os helpers do projeto (supervisorVe,
      // meuFuncionarioId, euSouODono) ja sao por fid. funcionarios/{fid} tem turno/setor.
      function alvoFunc(fid) { return get(/databases/$(database)/documents/funcionarios/$(fid)).data; }
      // Escopo do gestor sobre o alvo. Campo ausente no doc do alvo = erro = nega (fail-safe).
      function gestorNoEscopo(fid) {
        let a = alvoFunc(fid);
        return gpDesemp()
          || liderDoMesmoTurno(a.turno)
          || supervisorVe(fid)
          || supervisorVeTurno(a.turno);
      }
      // O alvo participa do ciclo? (casaTurno/casaSetor ja recebem o doc por argumento)
      function alvoNoPublico(fid) {
        let c = ciclo();
        let a = alvoFunc(fid);
        return c.publico.tipo == 'todos'
          || (c.publico.tipo == 'turno' && casaTurno(c.publico, a))
          || (c.publico.tipo == 'setor' && casaSetor(c.publico, a));
      }
      function cicloShapeOk() {
        return request.resource.data.nome is string
          && request.resource.data.nome.size() >= 1 && request.resource.data.nome.size() <= 120
          && request.resource.data.modalidade in ['gestor', 'auto']
          && request.resource.data.competencias is list
          && request.resource.data.competencias.size() >= 1 && request.resource.data.competencias.size() <= 12
          && request.resource.data.escalaMax is int
          && request.resource.data.escalaMax >= 3 && request.resource.data.escalaMax <= 10
          && request.resource.data.periodoInicio is timestamp
          && request.resource.data.periodoFim is timestamp
          && request.resource.data.publico.tipo in ['todos', 'turno', 'setor']
          && request.resource.data.publico.valores is list;
      }

      // Config: papel de gestao le (precisa pra avaliar); colaborador le ciclo ATIVO
      // (pra se autoavaliar) OU ENCERRADO (pra rotular o proprio resultado, que so
      // aparece no fechamento) em que participa. Rascunho o colaborador nunca le.
      allow read: if gpDesemp() || isLider() || isSupervisor()
                  || (isAuthed() && resource.data.status in ['ativo', 'encerrado'] && casaSegmento(resource.data.publico));
      allow create: if gpDesemp()
        && request.resource.data.status == 'rascunho'
        && request.resource.data.criadoPor == request.auth.uid
        && request.resource.data.criadoEm == request.time
        && cicloShapeOk();
      // 3 ramos (espelho do clima): editar rascunho ou ATIVAR; ativo so estende o
      // periodoFim; ativo -> encerrado one-way. Congela modalidade/competencias/
      // escalaMax/publico depois de ativo; encerrado e imutavel.
      allow update: if gpDesemp() && (
        ( resource.data.status == 'rascunho'
          && request.resource.data.criadoPor == resource.data.criadoPor
          && request.resource.data.criadoEm == resource.data.criadoEm
          && cicloShapeOk()
          && request.resource.data.status in ['rascunho', 'ativo']
          && ( request.resource.data.status == 'rascunho'
               || ( request.resource.data.ativadoEm == request.time
                    && request.resource.data.ativadoPor == request.auth.uid ) ) )
        ||
        ( resource.data.status == 'ativo'
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['periodoFim'])
          && request.resource.data.periodoFim is timestamp )
        ||
        ( resource.data.status == 'ativo'
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'encerradoEm', 'encerradoPor'])
          && request.resource.data.status == 'encerrado'
          && request.resource.data.encerradoEm == request.time
          && request.resource.data.encerradoPor == request.auth.uid )
      );
      allow delete: if isAdmin() || (gpDesemp() && resource.data.status == 'rascunho');

      // Avaliacoes: id DETERMINISTICO "{papel}_{alvoFid}" -- UMA avaliacao de gestor
      // (a oficial do ciclo) e UMA auto por alvo; re-salvar nao duplica e todo mundo
      // acha o doc por getDoc direto, sem query. avaliadorUid registra o ULTIMO autor
      // (outro gestor do escopo pode assumir o rascunho). papel 'auto' so na
      // modalidade 'auto' e so o proprio (participando do publico); papel 'gestor'
      // so gestor com o alvo no escopo E no publico do ciclo. Escrita so com ciclo
      // ATIVO; 'concluida' e imutavel (correcao administrativa = delete do gp, com
      // trilha em /eventos pela UI).
      match /avaliacoes/{avId} {
        function d() { return request.resource.data; }
        function avShapeOk() {
          return d().keys().hasOnly(['alvoFid', 'avaliadorUid', 'papel', 'notas', 'comentarios', 'feedbackGeral', 'status', 'atualizadoEm'])
            && d().alvoFid is string && d().avaliadorUid is string
            && d().papel in ['gestor', 'auto']
            && avId == d().papel + '_' + d().alvoFid
            && d().avaliadorUid == request.auth.uid
            && d().notas is map && d().notas.size() >= 1 && d().notas.size() <= 12
            && ( !('comentarios' in d()) || d().comentarios is map )
            && ( !('feedbackGeral' in d()) || (d().feedbackGeral is string && d().feedbackGeral.size() <= 2000) )
            && d().status in ['rascunho', 'concluida']
            && d().atualizadoEm == request.time;
        }
        function podeEscrever() {
          let c = ciclo();
          // request.time < periodoFim: sem isto o ramo "estender periodoFim" seria
          // decorativo e o ciclo ativo aceitaria avaliacao pra sempre (gate Fable).
          return isAuthed() && c.status == 'ativo' && request.time < c.periodoFim && avShapeOk()
            && (resource == null || resource.data.status == 'rascunho')
            && ( ( d().papel == 'auto'
                   && c.modalidade == 'auto'
                   && d().alvoFid == meuFuncionarioId()
                   && casaSegmento(c.publico) )
                 ||
                 ( d().papel == 'gestor'
                   && d().alvoFid != meuFuncionarioId()
                   && gestorNoEscopo(d().alvoFid)
                   && alvoNoPublico(d().alvoFid) ) );
        }
        // Le: o avaliador/autor a propria (qualquer status); gp tudo; o ALVO a que e
        // sobre si SO concluida E com o ciclo ENCERRADO (decisao William 2026-07-09:
        // o resultado chega pra todo mundo junto, no fechamento; um concluir
        // acidental do gestor nao expoe nada); o gestor do escopo le as concluidas
        // do escopo durante o ciclo (comparativo gestor x auto). Rascunho alheio
        // ninguem le.
        allow read: if isAuthed() && (
          resource.data.avaliadorUid == request.auth.uid
          || gpDesemp()
          || (resource.data.alvoFid == meuFuncionarioId() && resource.data.status == 'concluida'
              && ciclo().status == 'encerrado')
          || (resource.data.status == 'concluida' && gestorNoEscopo(resource.data.alvoFid))
        );
        allow create: if podeEscrever();
        allow update: if podeEscrever();
        allow delete: if gpDesemp();
      }
    }

    // ============================================================
    // GAMIFICACAO (2026-07-14) -- pontos por acao no Portal do Colaborador.
    // Temporada = doc por ANO (/gamificacao/2026); a virada e criar o do ano
    // seguinte (sem migracao). Anti-fraude SEM Cloud Functions, mesma liturgia
    // do contador do clima (ja auditada): o ponto e auto-declarado pelo dono,
    // mas a regra exige (a) id DETERMINISTICO {acao}_{refId} = dedup estrutural,
    // (b) pontos == tabela da config da temporada, (c) a PROVA da acao real
    // (exists/existsAfter do doc de assinatura/leitura/reacao correspondente,
    // que por sua vez so o dono consegue criar) e (d) o total do placar so
    // avanca junto de um evento nascendo no MESMO batch, com o valor exato.
    // PREMIOS SAO SURPRESA (decisao William): ficam FORA da config publica, em
    // /privado/premios (so cap); a entrega revela o premio ao dono.
    // Cap nova gamificacao.gerenciar e GLOBAL (NUNCA conceder 'turno'/'atrib').
    // Residuais documentados no PLANO-GAMIFICACAO.md: virada de ano avaliada em
    // UTC (BRT 21h-00h de 31/12 cai no ano novo) e eventos retroativos validos
    // (prova pre-existente conta: quem ja agiu no ano ganha ao ligar a feature).
    // ============================================================
    match /gamificacao/{ano} {
      function gpGami() { return isAdmin() || temCap('gamificacao.gerenciar', isRH()); }
      function cfg() { return get(/databases/$(database)/documents/gamificacao/$(ano)).data; }
      // O timestamp e "hoje"? ts = meia-noite LOCAL gravada pelo cliente; request.time
      // (UTC) tem que cair nas 24h daquele dia. Relogio do dispositivo errado = janela
      // nao casa = nega (fail-safe, so perde o dia).
      function diaEhHoje(ts) {
        return ts <= request.time && request.time < ts + duration.value(24, 'h');
      }
      function cfgShapeOk() {
        return request.resource.data.keys().hasOnly(['tabela', 'marcos', 'ativa', 'atualizadoEm', 'atualizadoPor'])
          && request.resource.data.tabela is map
          && request.resource.data.tabela.size() <= 20
          && request.resource.data.marcos is list
          && request.resource.data.marcos.size() <= 10
          && request.resource.data.ativa is bool
          && request.resource.data.atualizadoEm == request.time
          && request.resource.data.atualizadoPor == request.auth.uid;
      }

      // Config da temporada: tabela {acao: pts} + marcos [25,50,...] + ativa.
      // Read: qualquer autenticado (alimenta card/tela do colab; SEM premios aqui).
      allow read: if isAuthed();
      allow create, update: if gpGami() && cfgShapeOk();
      allow delete: if isAdmin();

      // Premios dos marcos (SURPRESA): so quem gerencia le/escreve.
      match /privado/{doc} {
        allow read, write: if gpGami();
      }

      // Presenca (streak de dias no app; DECISAO William 2026-07-14, supera a exclusao
      // de "login diario" do plano original -- registrada com LGPD no PLANO-GAMIFICACAO).
      // { dias, ultimoDia }: ultimoDia e a meia-noite LOCAL do dia marcado e SO pode ser
      // HOJE (diaEhHoje) -- presenca retroativa e IMPOSSIVEL de forjar. dias so avanca
      // +1 quando ultimoDia e exatamente o dia seguinte (24h cravadas; DST abolido no
      // Brasil); qualquer pulo reseta pra 1. Leitura: dono + GP (nada publico).
      match /presenca/{uid} {
        function p() { return request.resource.data; }
        function presencaShapeOk() {
          return p().keys().hasOnly(['dias', 'ultimoDia'])
            && p().dias is int
            && p().ultimoDia is timestamp
            && diaEhHoje(p().ultimoDia);
        }
        allow read: if gpGami() || (isAuthed() && request.auth.uid == uid);
        allow create: if isAuthed() && request.auth.uid == uid
          && presencaShapeOk() && p().dias == 1;
        allow update: if isAuthed() && request.auth.uid == uid
          && presencaShapeOk()
          && (
            ( p().ultimoDia == resource.data.ultimoDia + duration.value(24, 'h')
              && p().dias == resource.data.dias + 1 )
            ||
            ( p().ultimoDia > resource.data.ultimoDia + duration.value(24, 'h')
              && p().dias == 1 )
          );
        allow delete: if isAdmin();
      }

      // Placar por pessoa: { total, nome, ultimoEvento }. Leitura AMPLA autenticada
      // (ranking publico top 10 via orderBy total desc limit 10 -- e provada por esta
      // read; so total+nome expostos, mesmo residual de nome aceito no mural).
      // nome == users/{uid}.nome (anti-spoof, revalidado a cada escrita).
      // O total SO avanca acompanhado do evento apontado por ultimoEvento nascendo
      // no MESMO batch e com o valor EXATO (padrao contador clima). Sem caminho de
      // escrita fora disso: nem o proprio dono infla o placar.
      match /pontos/{uid} {
        function eventoNasceuAgora(eid) {
          return !exists(/databases/$(database)/documents/gamificacao/$(ano)/pontos/$(uid)/eventos/$(eid))
              && existsAfter(/databases/$(database)/documents/gamificacao/$(ano)/pontos/$(uid)/eventos/$(eid));
        }
        function pontosDoEvento(eid) {
          return getAfter(/databases/$(database)/documents/gamificacao/$(ano)/pontos/$(uid)/eventos/$(eid)).data.pontos;
        }
        // 'decoracao' DENORMALIZADA no placar com anti-spoof por igualdade (mesma
        // liturgia do nome): e assim que o aro equipado aparece pros colegas no
        // ranking, sem alargar a read de /users (que exporia foto/turno/setor/role
        // de todo mundo -- caminho vetado no gate).
        // 'foto' tambem denormalizada (William 2026-07-14: todos os funcionarios
        // autorizaram uso de imagem): mesma igualdade anti-spoof da decoracao/nome.
        function placarShapeOk() {
          return request.resource.data.keys().hasOnly(['total', 'nome', 'ultimoEvento', 'decoracao', 'foto'])
            && request.resource.data.total is int
            && request.resource.data.nome == userDoc().nome
            && (!('decoracao' in request.resource.data) || request.resource.data.decoracao == userDoc().decoracao)
            && (!('foto' in request.resource.data)
                || (request.resource.data.foto == userDoc().fotoBase64
                    && request.resource.data.foto.matches('data:image/.*')))
            && request.resource.data.ultimoEvento is string;
        }
        allow read: if isAuthed();
        allow create: if isAuthed() && request.auth.uid == uid
          && placarShapeOk()
          && eventoNasceuAgora(request.resource.data.ultimoEvento)
          && request.resource.data.total == pontosDoEvento(request.resource.data.ultimoEvento);
        allow update: if isAuthed() && request.auth.uid == uid && (
          ( placarShapeOk()
            && eventoNasceuAgora(request.resource.data.ultimoEvento)
            && request.resource.data.total == resource.data.total + pontosDoEvento(request.resource.data.ultimoEvento) )
          ||
          // Re-sincroniza SO o cosmetico (equipou aro / renomeou / trocou foto), sem
          // evento: total e ultimoEvento fora do hasOnly do diff, zero caminho de inflar.
          ( request.resource.data.diff(resource.data).affectedKeys().hasOnly(['decoracao', 'nome', 'foto'])
            && request.resource.data.nome == userDoc().nome
            && (!('decoracao' in request.resource.data) || request.resource.data.decoracao == userDoc().decoracao)
            && (!('foto' in request.resource.data)
                || (request.resource.data.foto == userDoc().fotoBase64
                    && request.resource.data.foto.matches('data:image/.*'))) )
        );
        allow delete: if isAdmin();

        // Evento de ponto: id {acao}_{refId} (dedup estrutural: repetir a acao no
        // mesmo alvo colide no mesmo id e vira update -> negado). pontos vem da
        // tabela da config; a PROVA amarra o evento a acao REAL. existsAfter e
        // proposital: cobre prova criada no MESMO batch E prova pre-existente
        // (retroativo valido). 'rotulo' e cosmetico do extrato (self + GP; auto-
        // relato, mesmo status do /eventos de auditoria). Append-only.
        match /eventos/{eid} {
          function d() { return request.resource.data; }
          // Toda prova carrega server-time ('em'/'atualizadoEm' == request.time nas regras
          // de origem): o year-gate abaixo tranca o retroativo DENTRO do ano da prova
          // (gate Fable 2026-07-14, bloqueador 3: sem ele, a virada de temporada
          // recreditava a vida inteira). Residual aceito: acao de ~31/12 avaliada em UTC
          // pode cair no ano seguinte e perder o ponto, 1 dia por ano.
          // 'pesquisa' e exists+get PRE-batch de proposito (bloqueador 2): o evento nunca
          // nasce no MESMO commit da resposta anonima, senao o par de timestamps iguais
          // (em do evento x createTime da resposta) desanonimizaria por join exato. O
          // cliente reivindica o ponto DEPOIS (proxima abertura do app).
          // coracao/boas-vindas DESTRAVADOS 2026-07-15: o pipeline (WKRADAR) agora
          // grava o DOC PAI /muralAniversario/{postId} (aniv-<slug>-<anoAtual> tipo
          // 'aniversario'; bv-<slug>-<anoDaAdmissao> tipo 'bemvindo'), entao a prova
          // e real: pai existe com o tipo certo + a MINHA reacao (getAfter) e DESTE
          // ano + anti-auto (nome do pai != meu nome). Year-gate: no coracao o
          // proprio postId termina no ano corrente; no bv o ano e o da ADMISSAO
          // (dezembro na janela vira janeiro), quem fecha re-claim anual e o em da
          // reacao + a PODA dos pais fora da janela (WKRADAR, PRAZO: rodando antes
          // de 2027-01-01; gate 2026-07-15). Magnitude do residual ate la: 1 ponto
          // por ANO por pai bv- orfao sobrevivente (claim auditavel no extrato).
          // Upgrade futuro anotado: pai ganhar funcionarioId e o anti-auto migrar
          // de nome pra meuFuncionarioId() (imune a grafia).
          function provaOk(acao, refId) {
            return (acao == 'cartao-ponto'
                     && getAfter(/databases/$(database)/documents/recibos/$(refId)/assinaturas/$(uid)).data.em.year() == request.time.year()
                     && get(/databases/$(database)/documents/recibos/$(refId)).data.tipo == 'cartao-ponto')
              || (acao == 'folha'
                     && getAfter(/databases/$(database)/documents/recibos/$(refId)/assinaturas/$(uid)).data.em.year() == request.time.year()
                     && get(/databases/$(database)/documents/recibos/$(refId)).data.tipo != 'cartao-ponto')
              || (acao == 'comunicado'
                     && getAfter(/databases/$(database)/documents/comunicados/$(refId)/leituras/$(uid)).data.em.year() == request.time.year())
              // O aceite REAL do app vive em leituras/{uid} com confirmado == true (a
              // subcolecao aceites/ da regra existe mas o front nunca a usou); provar
              // por aceites/ seria provar um doc que nunca nasce. Mesma classe do
              // comunicado ja aprovada no gate: em e server-time gravado pelo cliente,
              // forjar em leitura nova nao rende alem do ponto legitimo (create-only).
              // ponytail: se o front da task 72 migrar o aceite pra aceites/{uid}, este
              // ramo ganha o OR do aceites (aditivo; o id deterministico do evento
              // impede double-claim pelas duas provas). NAO "consertar" de volta antes.
              || (acao == 'documento-leitura'
                     && getAfter(/databases/$(database)/documents/documentos/$(refId)/leituras/$(uid)).data.confirmado == true
                     && getAfter(/databases/$(database)/documents/documentos/$(refId)/leituras/$(uid)).data.em.year() == request.time.year())
              || (acao == 'documento-assinatura'
                     && getAfter(/databases/$(database)/documents/documentos/$(refId)/assinaturas/$(uid)).data.em.year() == request.time.year())
              || (acao == 'pesquisa'
                     && exists(/databases/$(database)/documents/pesquisasClima/$(refId)/recibos/$(uid))
                     && get(/databases/$(database)/documents/pesquisasClima/$(refId)/recibos/$(uid)).data.em.year() == request.time.year())
              || (acao == 'autoavaliacao'
                     && getAfter(/databases/$(database)/documents/avaliacaoCiclos/$(refId)/avaliacoes/$('auto_' + meuFuncionarioId())).data.status == 'concluida'
                     && getAfter(/databases/$(database)/documents/avaliacaoCiclos/$(refId)/avaliacoes/$('auto_' + meuFuncionarioId())).data.atualizadoEm.year() == request.time.year())
              || (acao == 'termo'
                     && refId == uid
                     && getAfter(/databases/$(database)/documents/termoAdesao/$(uid)).data.em.year() == request.time.year())
              // Foto de perfil propria (William 2026-07-14): prova = users/{uid}.fotoBase64
              // com dataURL de imagem (a definicao de "tem foto" da propria UI; barra lixo).
              // SEM year-gate de proposito: prova de ESTADO, e o produto quer "1x por
              // temporada" -- o id foto_{uid} na arvore DO ANO da o dedup anual.
              // DECISAO do William (gate Fable delta 3): o ponto e SO PELO ATO de trocar/
              // adicionar a foto pelo app -- o CLIENTE nunca reivindica no catch-up (as 73
              // fotos OFICIAIS importadas vivem neste mesmo campo e nao podem virar brinde
              // em massa). Residual aceito: claim manual via console por quem ja tem foto,
              // teto estrutural de 1 ponto por temporada.
              || (acao == 'foto'
                     && refId == uid
                     && getAfter(/databases/$(database)/documents/users/$(uid)).data.fotoBase64.matches('data:image/.*'))
              // Streak: prova = doc de presenca com ultimoDia HOJE e dias em multiplo de 5.
              // O refId deriva do ULTIMODIA DA PRESENCA (nao de request.time): um estado
              // elegivel gera exatamente UM id possivel. Derivar do request.time abriria
              // double-claim na virada de meia-noite UTC dentro da mesma janela de 24h
              // (gate Fable delta 4). ultimoDia e monotonico pelos ramos do update, entao
              // cada dia canonico aparece no maximo 1x por uid.
              // Anti-auto em DUPLA (upgrade do gate, 2026-07-15): o pipeline agora
              // grava funcionarioId no pai; exigir id E nome diferentes e imune a
              // grafia (id) e a formato divergente de id (nome segura). Pai antigo
              // sem funcionarioId = erro de avaliacao = NEGA (fail-closed; a poda
              // recria os pais toda rodada ja com o campo).
              || (acao == 'coracao'
                     && get(/databases/$(database)/documents/muralAniversario/$(refId)).data.tipo == 'aniversario'
                     && refId.matches('.*-' + string(request.time.year()))
                     && getAfter(/databases/$(database)/documents/muralAniversario/$(refId)/reacoes/$(uid)).data.em.year() == request.time.year()
                     && get(/databases/$(database)/documents/muralAniversario/$(refId)).data.funcionarioId != meuFuncionarioId()
                     && get(/databases/$(database)/documents/muralAniversario/$(refId)).data.nome != userDoc().nome)
              || (acao == 'boas-vindas'
                     && get(/databases/$(database)/documents/muralAniversario/$(refId)).data.tipo == 'bemvindo'
                     && getAfter(/databases/$(database)/documents/muralAniversario/$(refId)/reacoes/$(uid)).data.em.year() == request.time.year()
                     && get(/databases/$(database)/documents/muralAniversario/$(refId)).data.funcionarioId != meuFuncionarioId()
                     && get(/databases/$(database)/documents/muralAniversario/$(refId)).data.nome != userDoc().nome)
              // Tempo de casa (2026-07-17): espelho do coracao, so muda o tipo do pai.
              // Year-gate identico ao aniv-: o sufixo do postId e o ano CORRENTE
              // (pipeline recria por ano), entao o matches segura re-claim de pai velho.
              || (acao == 'tempo-casa'
                     && get(/databases/$(database)/documents/muralAniversario/$(refId)).data.tipo == 'tempo-casa'
                     && refId.matches('.*-' + string(request.time.year()))
                     && getAfter(/databases/$(database)/documents/muralAniversario/$(refId)/reacoes/$(uid)).data.em.year() == request.time.year()
                     && get(/databases/$(database)/documents/muralAniversario/$(refId)).data.funcionarioId != meuFuncionarioId()
                     && get(/databases/$(database)/documents/muralAniversario/$(refId)).data.nome != userDoc().nome)
              || (acao == 'streak'
                     && refId == string(getAfter(/databases/$(database)/documents/gamificacao/$(ano)/presenca/$(uid)).data.ultimoDia.year())
                          + '-' + string(getAfter(/databases/$(database)/documents/gamificacao/$(ano)/presenca/$(uid)).data.ultimoDia.month())
                          + '-' + string(getAfter(/databases/$(database)/documents/gamificacao/$(ano)/presenca/$(uid)).data.ultimoDia.day())
                     && getAfter(/databases/$(database)/documents/gamificacao/$(ano)/presenca/$(uid)).data.dias > 0
                     && getAfter(/databases/$(database)/documents/gamificacao/$(ano)/presenca/$(uid)).data.dias % 5 == 0
                     && diaEhHoje(getAfter(/databases/$(database)/documents/gamificacao/$(ano)/presenca/$(uid)).data.ultimoDia));
          }
          allow read: if gpGami() || (isAuthed() && request.auth.uid == uid);
          allow create: if isAuthed() && request.auth.uid == uid
            && d().keys().hasOnly(['acao', 'refId', 'pontos', 'rotulo', 'em'])
            && d().acao is string && d().acao.size() <= 40
            && d().refId is string && d().refId.size() >= 1 && d().refId.size() <= 200
            && eid == d().acao + '_' + d().refId
            && d().em == request.time
            && (!('rotulo' in d()) || (d().rotulo is string && d().rotulo.size() <= 140))
            && cfg().ativa == true
            && string(request.time.year()) == ano
            && d().acao in cfg().tabela
            && d().pontos is int && d().pontos > 0
            && d().pontos == cfg().tabela[d().acao]
            && provaOk(d().acao, d().refId);
          allow update, delete: if false;
        }
      }

      // Entrega de premio de marco: registro da GP (trilha de quem entregou o que
      // e quando), IMUTAVEL, id {uid}_{marco} (uma entrega por marco por pessoa).
      // O dono le as proprias (query where uid == auth.uid -- provada pela regra):
      // e assim que o premio de um marco cruzado e REVELADO pro colaborador.
      match /entregas/{eid} {
        function e() { return request.resource.data; }
        allow read: if gpGami() || (isAuthed() && resource.data.uid == request.auth.uid);
        allow create: if gpGami()
          && e().keys().hasOnly(['uid', 'marco', 'premio', 'em', 'porUid'])
          && e().uid is string
          && e().marco is int && e().marco > 0
          && eid == e().uid + '_' + string(e().marco)
          && e().premio is string && e().premio.size() >= 1 && e().premio.size() <= 200
          && e().em == request.time
          && e().porUid == request.auth.uid;
        allow update: if false;
        allow delete: if isAdmin();
      }
    }

    // ============================================================
    // VAGAS (2026-07-14, decisao William: v1 SO PUBLICO). A pagina
    // vagas.fiobras.com.br le SEM LOGIN: e a PRIMEIRA leitura publica do
    // projeto, entao a fronteira e estreita DE PROPOSITO: anonimo le
    // EXCLUSIVAMENTE vaga com status 'publicada' (query where status ==
    // 'publicada' e provada; rascunho/encerrada negam) e o doc config/vagas
    // (so o WhatsApp de candidaturas, publico por PROPOSITO). Nenhuma
    // escrita anonima em lugar nenhum. Conteudo de vaga nao tem PII.
    // Vagas internas (colaborador se candidata) = fase 2 no roadmap.
    // ============================================================
    match /vagas/{id} {
      function gpVagas() { return isAdmin() || temCap('vagas.gerenciar', isRH()); }
      function v() { return request.resource.data; }
      function vagaShapeOk() {
        return v().keys().hasOnly(['titulo', 'setor', 'turno', 'cidade', 'tipo', 'descricao', 'requisitos', 'status', 'criadoPor', 'criadoEm', 'publicadaEm', 'encerradaEm', 'beneficios'])
          && v().titulo is string && v().titulo.size() >= 1 && v().titulo.size() <= 120
          && v().descricao is string && v().descricao.size() <= 3000
          && (!('requisitos' in v()) || (v().requisitos is string && v().requisitos.size() <= 3000))
          && (!('setor' in v()) || (v().setor is string && v().setor.size() <= 60))
          && (!('turno' in v()) || (v().turno is string && v().turno.size() <= 40))
          && (!('cidade' in v()) || (v().cidade is string && v().cidade.size() <= 60))
          && (!('tipo' in v()) || (v().tipo is string && v().tipo.size() <= 30))
          // Beneficios marcados pra esta vaga: OPCIONAL, lista <=15 de strings 1..40.
          // Shape-only (sem cross-check com o catalogo, o front restringe).
          && (!('beneficios' in v()) || (v().beneficios is list && v().beneficios.size() <= 15 && benefStrings(v().beneficios)));
      }
      allow read: if resource.data.status == 'publicada' || gpVagas();
      allow create: if gpVagas()
        && vagaShapeOk()
        && v().status == 'rascunho'
        && v().criadoPor == request.auth.uid
        && v().criadoEm == request.time;
      // 3 ramos: editar rascunho ou PUBLICAR; publicada aceita correcao de conteudo
      // (sem tocar status/publicadaEm); publicada -> encerrada one-way (nunca reabre:
      // quem quer republicar cria vaga nova, a trilha de datas fica honesta).
      allow update: if gpVagas() && (
        ( resource.data.status == 'rascunho'
          && vagaShapeOk()
          && v().criadoPor == resource.data.criadoPor
          && v().criadoEm == resource.data.criadoEm
          && v().status in ['rascunho', 'publicada']
          && ( v().status == 'rascunho' || v().publicadaEm == request.time ) )
        ||
        ( resource.data.status == 'publicada'
          && vagaShapeOk()
          && v().status == 'publicada'
          && v().criadoPor == resource.data.criadoPor
          && v().criadoEm == resource.data.criadoEm
          && v().publicadaEm == resource.data.publicadaEm )
        ||
        ( resource.data.status == 'publicada'
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'encerradaEm'])
          && v().status == 'encerrada'
          && v().encerradaEm == request.time )
      );
      // Excluir: rascunho ou encerrada (William 2026-07-14). Publicada NUNCA direto:
      // encerra antes (one-way preservado, a trilha publicadaEm/encerradaEm fica honesta).
      allow delete: if isAdmin() || (gpVagas() && resource.data.status in ['rascunho', 'encerrada']);
    }

    // ============================================================
    // CANAL DE DENUNCIA (2026-07-15, William: "apenas admin ve").
    // Desenho de sigilo: (1) ANONIMATO ESTRUTURAL, o hasOnly nem permite campo
    // de uid/nome/aparelho, entao nem erro de cliente consegue vazar a autoria
    // de uma denuncia anonima; (2) identificar-se e ESCOLHA do denunciante,
    // por denuncia, via campo contato (texto livre que ELE digita); (3)
    // leitura, triagem e exclusao SO ADMIN, de proposito FORA da matriz de
    // permissoes (cap configuravel poderia ser delegada por engano, e denuncia
    // pode ser sobre a propria GP); (4) create exige login (gente do quadro),
    // mas o doc criado nao guarda quem foi; ID aleatorio.
    // Residuais aceitos (gate 2026-07-15): (a) correlacao temporal (quem
    // estava logado no minuto X) so e visivel a quem opera o proprio projeto
    // Firebase, que ja e o admin destinatario; reduzir a precisao do 'em'
    // seria teatro (createTime dos metadados guarda o instante exato).
    // (b) SEM rate limit de proposito: marcador por uid vazaria exatamente a
    // correlacao que o desenho elimina; flood e visivel e o autor e do quadro.
    // ponytail: App Check se um dia abusarem. (c) Protocolo de acompanhamento
    // pro denunciante = roadmap; o hash exibido na confirmacao ja serve de
    // comprovante de envio e integridade.
    // GUARDAS DE FRONT obrigatorias (gate): add() com ID aleatorio (nunca ID
    // derivado), ZERO logEvento/analytics no fluxo, nada em localStorage
    // ligando conta a denuncia, contato exibido ao admin como NAO VERIFICADO.
    // ============================================================
    match /denuncias/{id} {
      function den() { return request.resource.data; }
      // Categorias alinhadas a Lei 14.457/2022 (canal obrigatorio p/ empresas
      // com CIPA: assedio sexual e outras violencias) + LGPD/compliance.
      // HASH DE AUTENTICIDADE (pedido William 2026-07-15): o cliente manda o
      // sha256 do relato e a REGRA recalcula e confere; com texto e hash
      // imutaveis pos-create, qualquer adulteracao posterior e detectavel.
      allow create: if request.auth != null
        && den().keys().hasOnly(['categoria', 'texto', 'hash', 'contato', 'em', 'status', 'codigoAcompanhamento'])
        && den().categoria in ['assedio-sexual', 'assedio-moral', 'discriminacao', 'violencia', 'seguranca', 'fraude', 'outro']
        && den().texto is string && den().texto.size() >= 10 && den().texto.size() <= 5000
        && den().hash is string
        && den().hash.lower() == hashing.sha256(den().texto).toHexString().lower()
        && (!('contato' in den().keys()) || (den().contato is string && den().contato.size() <= 200))
        // PROTOCOLO DE ACOMPANHAMENTO (2026-07-16): codigo OPCIONAL, aleatorio forte
        // gerado no cliente, que liga esta denuncia ao espelho content-free
        // /denunciaStatus/{codigo} (a triagem sabe qual andamento atualizar). NAO
        // enfraquece o anonimato: o codigo e um bearer token aleatorio, nao deriva de
        // pessoa (uid/CPF/nome), nao identifica autor nem correlaciona denuncias do
        // mesmo autor (cada envio gera um codigo novo). Imutavel pos-create: a regra de
        // update (hasOnly abaixo) nao o inclui em affectedKeys, logo nao ha como alterar.
        && (!('codigoAcompanhamento' in den().keys())
            || (den().codigoAcompanhamento is string && den().codigoAcompanhamento.size() >= 12 && den().codigoAcompanhamento.size() <= 40))
        && den().em == request.time
        && den().status == 'nova';
      allow read: if isAdmin();
      // Triagem v2 (governanca, William 2026-07-16): alem de status e nota, o admin
      // registra o DESFECHO e o carimbo concluidaEm ao ENCERRAR, e pode ligar/desligar
      // guardaPermanente (caso gravissimo que nunca e expurgado). O RELATO original, o
      // hash, a categoria e o em seguem IMUTAVEIS (integridade da apuracao).
      allow update: if isAdmin()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'nota', 'desfecho', 'concluidaEm', 'guardaPermanente'])
        && request.resource.data.status in ['nova', 'em_analise', 'concluida']
        && (!('nota' in request.resource.data.keys()) || (request.resource.data.nota is string && request.resource.data.nota.size() <= 2000))
        && (!('desfecho' in request.resource.data.keys()) || request.resource.data.desfecho in ['procedente', 'improcedente', 'sem-elementos'])
        && (!('guardaPermanente' in request.resource.data.keys()) || request.resource.data.guardaPermanente is bool)
        // Concluir EXIGE desfecho e carimbo de conclusao: nao ha encerramento sem registro.
        && (request.resource.data.status != 'concluida'
            || ('desfecho' in request.resource.data.keys() && 'concluidaEm' in request.resource.data.keys()))
        // concluidaEm, quando escrito, e o instante do servidor (nunca data arbitraria do cliente).
        && (!('concluidaEm' in request.resource.data.diff(resource.data).affectedKeys())
            || request.resource.data.concluidaEm == request.time)
        // SELO DE 24 HORAS (William 2026-07-15): dentro da janela de 24h da conclusao o
        // admin ainda ajusta (nota/desfecho/guarda) ou ate REABRE pra em_analise e
        // re-conclui (a transicao re-carimba concluidaEm). Passadas as 24h o registro
        // SELA: NENHUM update passa, nem do admin (fato novo = caso novo). Denuncia
        // LEGADA concluida SEM concluidaEm: o default request.time faz a trava NAO pegar,
        // segue editavel ate ganhar uma conclusao carimbada.
        && !( resource.data.status == 'concluida'
              && resource.data.get('concluidaEm', request.time) < request.time - duration.value(24, 'h') );
      // Excluir = GOVERNANCA + LGPD (William 2026-07-16, "nao deveria poder deletar,
      // apenas tratar"): nem o admin apaga antes da hora. So sai denuncia CONCLUIDA,
      // depois do PISO de retencao de 5 anos (1825 dias) contados da conclusao, e
      // NUNCA se marcada como guarda permanente (caso gravissimo, fica para sempre).
      allow delete: if isAdmin()
        && resource.data.status == 'concluida'
        && resource.data.get('guardaPermanente', false) != true
        && resource.data.get('concluidaEm', request.time) is timestamp
        && resource.data.get('concluidaEm', request.time) < request.time - duration.value(1825, 'd');
    }

    // ============================================================
    // PROTOCOLO DE ACOMPANHAMENTO da denuncia (2026-07-16, William).
    // Espelho content-free do andamento: o denunciante guarda o codigo (bearer
    // token aleatorio forte, gerado no cliente) e consulta SO o status, sem ver
    // relato/PII/desfecho/nota. Desenho de sigilo, casa com /denuncias:
    //  - O doc carrega APENAS status e carimbos de tempo, ZERO conteudo e ZERO
    //    PII, entao expor o get por id ao publico nao vaza nada da apuracao.
    //  - GET por id: aberto (quem tem o codigo le o proprio andamento, e o desenho).
    //  - LIST: negado EXPLICITO. Ninguem enumera a colecao (anti-varredura): sem
    //    isso, um list vazaria o conjunto de codigos e o volume de denuncias.
    //  - CREATE: mesmo autor anonimo do envio (autenticado do quadro), junto da
    //    denuncia; shape fechado hasOnly(status,em) com status=='nova' e em==server,
    //    e id com tamanho sano (12..40) pra barrar ids triviais tipo "1". O doc NUNCA
    //    ganha desfecho/nota/relato (o publico veria) porque o hasOnly nem os permite.
    //  - UPDATE: SO admin, e so pra refletir o andamento (status + atualizadoEm
    //    carimbado no servidor); affectedKeys fechado nega qualquer campo de conteudo.
    //  - DELETE: SO admin, SEM a trava de 5 anos da /denuncias. Decisao (justificada):
    //    a trava de retencao existe pra proteger o RELATO/apuracao (LGPD, integridade);
    //    o espelho nao tem conteudo nenhum, entao nao ha nada a reter. Espelhar a trava
    //    exigiria denormalizar desfecho/concluidaEm aqui, contrariando o "zero conteudo"
    //    e podendo deixar espelho ORFAO apontando pra denuncia ja expurgada. Admin-only
    //    e o suficiente: o expurgo LGPD da denuncia varre o espelho junto.
    // ============================================================
    match /denunciaStatus/{codigo} {
      function st() { return request.resource.data; }
      allow create: if request.auth != null
        && codigo.size() >= 12 && codigo.size() <= 40
        && st().keys().hasOnly(['status', 'em'])
        && st().status == 'nova'
        && st().em == request.time;
      allow get: if true;
      allow list: if false;
      allow update: if isAdmin()
        && st().diff(resource.data).affectedKeys().hasOnly(['status', 'atualizadoEm'])
        && st().status in ['nova', 'em_analise', 'concluida']
        && st().atualizadoEm == request.time;
      allow delete: if isAdmin();
    }

    // ============================================================
    // CANDIDATURAS (2026-07-14, William: formulario NO SITE, sem WhatsApp).
    // PRIMEIRA ESCRITA ANONIMA do projeto, entao a porta e um funil:
    // create-only, shape fechado (hasOnly), caps de tamanho em tudo, vaga
    // alvo obrigatoriamente 'publicada' (get) e doc ID DETERMINISTICO
    // vagaId__email (anti-spam estrutural: 1 candidatura por email por
    // vaga; repeticao vira update, que NEGA). PII de candidato EXTERNO
    // (nome/telefone/email): leitura e exclusao SO da GP (LGPD, o site
    // mostra consentimento no form). Residual aceito e documentado no
    // PLANO-VAGAS.md: sem captcha/App Check um bot pode variar emails;
    // mitiga o funil acima, a GP exclui e o upgrade path e App Check.
    // ============================================================
    match /candidaturas/{cid} {
      function gpCand() { return isAdmin() || temCap('vagas.gerenciar', isRH()); }
      function c() { return request.resource.data; }
      // Uma experiencia profissional (0..3 por ficha). hasOnly fecha o shape (sem
      // campo extra); os is/size garantem que as 5 chaves existem e sao sanas.
      function expOk(e) {
        return e is map
          && e.keys().hasOnly(['empresa', 'admissao', 'demissao', 'salario', 'motivoSaida'])
          && e.empresa is string && e.empresa.size() >= 1 && e.empresa.size() <= 80
          && e.admissao is string && e.admissao.matches('[0-9]{4}-[0-9]{2}-[0-9]{2}')
          // demissao vazia '' = EMPREGO ATUAL (candidato ainda trabalha na empresa);
          // a chave segue obrigatoria no shape (hasOnly + is string), so o valor ganha o
          // caso vazio, sem inventar data de saida (William, smoke 2026-07-15).
          && e.demissao is string && (e.demissao == '' || e.demissao.matches('[0-9]{4}-[0-9]{2}-[0-9]{2}'))
          && e.salario is number && e.salario > 0 && e.salario <= 1000000
          && e.motivoSaida is string && e.motivoSaida.size() >= 1 && e.motivoSaida.size() <= 120;
      }
      allow read: if gpCand();
      // FICHA COMPLETA (v4, lista da GP, mock aprovado 2026-07-15). O create NOVO exige
      // os dados que a GP pediu (estadoCivil, escolaridade, filhos, endereco,
      // nacionalidade, naturalidade, experiencias, pretensaoSalarial, comoViria,
      // indicacao) e nascimento passa a ser OBRIGATORIO. curriculoPath e o teste de
      // perfil (disc/discPrimario) seguem OPCIONAIS e aditivos. Docs v3 antigos
      // (sem os novos campos) NAO passam mais no create novo, mas seguem legiveis e
      // deletaveis pela GP (read/delete nao checam shape). O resultado do teste e
      // AUTO-DECLARADO pelo cliente (indicativo por design); os caps so garantem shape sano.
      allow create: if c().keys().hasOnly(['vagaId', 'vagaTitulo', 'nome', 'telefone', 'email', 'mensagem', 'em', 'status', 'nascimento', 'estadoCivil', 'escolaridade', 'filhos', 'endereco', 'nacionalidade', 'naturalidade', 'experiencias', 'pretensaoSalarial', 'comoViria', 'indicacao', 'disc', 'discPrimario', 'curriculoPath'])
        // --- NOVOS obrigatorios (ficha da GP) ---
        && c().estadoCivil in ['solteiro', 'casado', 'uniao-estavel', 'divorciado', 'viuvo']
        && c().escolaridade in ['fundamental', 'medio-incompleto', 'medio-completo', 'tecnico', 'superior-incompleto', 'superior-completo', 'pos']
        && c().filhos is int && c().filhos >= 0 && c().filhos <= 20
        && c().endereco is string && c().endereco.size() >= 1 && c().endereco.size() <= 200
        && c().nacionalidade is string && c().nacionalidade.size() >= 1 && c().nacionalidade.size() <= 60
        && c().naturalidade is string && c().naturalidade.size() >= 1 && c().naturalidade.size() <= 60
        && c().nascimento is string && c().nascimento.matches('[0-9]{4}-[0-9]{2}-[0-9]{2}')
        // experiencias 0..3 (0 = primeiro emprego); validacao por indice com curto-circuito.
        && c().experiencias is list && c().experiencias.size() <= 3
        && (c().experiencias.size() < 1 || expOk(c().experiencias[0]))
        && (c().experiencias.size() < 2 || expOk(c().experiencias[1]))
        && (c().experiencias.size() < 3 || expOk(c().experiencias[2]))
        && c().pretensaoSalarial is number && c().pretensaoSalarial > 0 && c().pretensaoSalarial <= 1000000
        && c().comoViria in ['a-pe', 'bicicleta', 'moto', 'carro', 'carona', 'onibus']
        && c().indicacao is string && c().indicacao.size() <= 80
        // --- OPCIONAIS aditivos (retrocompat de validacao) ---
        && (!('disc' in c().keys()) || (c().disc is map
              && c().disc.keys().hasOnly(['d', 'i', 's', 'c'])
              && c().disc.d is int && c().disc.d >= -8 && c().disc.d <= 8
              && c().disc.i is int && c().disc.i >= -8 && c().disc.i <= 8
              && c().disc.s is int && c().disc.s >= -8 && c().disc.s <= 8
              && c().disc.c is int && c().disc.c >= -8 && c().disc.c <= 8))
        && (!('discPrimario' in c().keys()) || c().discPrimario in ['D', 'I', 'S', 'C', 'equilibrado'])
        && (!('curriculoPath' in c().keys()) || (c().curriculoPath is string && c().curriculoPath.size() <= 220 && c().curriculoPath.matches('curriculos/[A-Za-z0-9@._-]+\\.pdf')))
        // --- Existentes (intocados) ---
        && c().vagaId is string && c().vagaId.size() >= 1 && c().vagaId.size() <= 60
        && get(/databases/$(database)/documents/vagas/$(c().vagaId)).data.status == 'publicada'
        // Igualdade com a vaga real (gate): mata titulo enganoso; mesmo doc do get
        // acima, o acesso repetido e cacheado, zero read extra.
        && c().vagaTitulo is string && c().vagaTitulo.size() <= 120
        && c().vagaTitulo == get(/databases/$(database)/documents/vagas/$(c().vagaId)).data.titulo
        && c().nome is string && c().nome.size() >= 3 && c().nome.size() <= 80
        && c().telefone is string && c().telefone.size() >= 8 && c().telefone.size() <= 20
        && c().email is string && c().email.size() >= 5 && c().email.size() <= 120
        && c().email.matches('[^@\\s]+@[^@\\s]+\\.[^@\\s]+')
        && c().mensagem is string && c().mensagem.size() <= 1000
        && c().em == request.time
        && c().status == 'nova'
        && cid == c().vagaId + '__' + c().email.lower();
      // FUNIL DE STATUS (fase 1, 2026-07-16): a GP move a candidatura entre os 4
      // passos do funil, e SO isso. gpCand troca UNICAMENTE o campo status
      // (affectedKeys hasOnly) e so pra um valor do enum; todo o resto do cadastro
      // (PII do candidato) segue IMUTAVEL. Docs criados pelo site nascem com status
      // 'nova' (create acima, public-vagas intocado); o front trata 'nova'/ausente
      // como Recebida e sobe pro enum novo no primeiro toque. Sem transicao proibida:
      // qualquer um dos 4 vai pra qualquer um (a GP corrige um clique errado).
      allow update: if gpCand()
        && c().diff(resource.data).affectedKeys().hasOnly(['status'])
        && c().status in ['recebida', 'em-analise', 'aprovada', 'nao-seguiu'];
      allow delete: if gpCand();
    }

    // WhatsApp de candidaturas: publico por proposito (a pagina aberta precisa).
    // Coexiste com o match generico /config/{doc} (matches sobrepostos = OR).
    // Shape-lock (gate): doc PUBLICO pra internet; erro operacional da GP (colar
    // texto errado) nao pode publicar conteudo arbitrario. Residual aceito: o match
    // generico /config/{doc} deixa ADMIN escrever sem shape (papel confiavel).
    match /config/vagas {
      allow read: if true;
      allow write: if (isAdmin() || temCap('vagas.gerenciar', isRH()))
        && request.resource.data.keys().hasOnly(['whatsapp', 'beneficiosCatalogo'])
        && request.resource.data.whatsapp is string
        && request.resource.data.whatsapp.size() <= 30
        // Catalogo de beneficios (a GP mantem 1x, marca por vaga): OPCIONAL e aditivo
        // (o doc so-whatsapp de hoje continua valido). Lista <=30 de strings 1..40.
        && (!('beneficiosCatalogo' in request.resource.data.keys())
            || (request.resource.data.beneficiosCatalogo is list
                && request.resource.data.beneficiosCatalogo.size() <= 30
                && benefStrings(request.resource.data.beneficiosCatalogo)));
    }

    // ============================================================
    // FILA DE EMAILS (extensao Trigger Email, 2026-07-16). A extensao processa
    // /mail via Admin SDK (IGNORA estas rules) e monta o corpo a partir dos
    // moldes em /emailTemplates. As rules governam SO os clientes: o desenho e
    // anti-spam ESTRUTURAL, ninguem usa o remetente da Fiobras pra nada fora do
    // funil de candidaturas. A propriedade que as duas portas garantem: um email
    // so pode ir pro proprio email de uma candidatura REAL, com molde PINADO, e
    // no maximo 1 vez por (candidatura, template) -- o doc id e deterministico e
    // create-only, entao repetir vira update, que NEGA.
    //   (a) EMAIL 1 (anonimo, molde 'candidatura-recebida'): sai junto do envio
    //       da candidatura, no MESMO batch; o id do mail E o id da candidatura e
    //       o to tem que ser o email dela (getAfter ve o irmao criado junto). O
    //       existsAfter tambem casa candidatura pre-existente, e ta OK: o to
    //       segue travado no email dela e o id trava 1 recebida por candidatura,
    //       entao nao ha amplificacao (nunca email pra endereco arbitrario nem
    //       repetido).
    //   (b) EMAILS DE STATUS (pela GP, cap vagas.gerenciar): a candidatura JA
    //       existe; o id do mail e '<candidaturaId>-<status>' (status in
    //       em-analise/aprovada/nao-seguiu) e o to tem que ser o email dela. O
    //       candidaturaId sai do proprio mailId tirando o sufixo '-<status>'
    //       (replace ancorado em $) e e RE-CONFIRMADO por concatenacao
    //       (mailId == candId + '-' + status): strip+concat e airtight mesmo que
    //       o email da candidatura contenha o texto de um status. Cada status e
    //       um ramo EXPLICITO (nao deriva string de template.name): lixo em
    //       template.name/id cai fora dos 3 e NEGA.
    //   READ/UPDATE/DELETE de cliente: false. O doc ganha PII do candidato (to)
    //   e status de entrega escrito pela extensao; so a extensao (Admin SDK) mexe.
    // ============================================================
    match /mail/{mailId} {
      function gpCand() { return isAdmin() || temCap('vagas.gerenciar', isRH()); }
      function m() { return request.resource.data; }
      // template.data e so DISPLAY (primeiro nome do candidato + titulo da vaga):
      // shape-only, strings sanas. O anti-spam vem do to travado no email da
      // candidatura + do molde pinado + do id deterministico, nao deste conteudo.
      function moldeOk(nome) {
        return m().keys().hasOnly(['to', 'template'])
          && m().to is string
          && m().template is map
          && m().template.keys().hasOnly(['name', 'data'])
          && m().template.name == nome
          && m().template.data is map
          && m().template.data.keys().hasOnly(['nome', 'vaga'])
          && m().template.data.nome is string
          && m().template.data.nome.size() >= 1 && m().template.data.nome.size() <= 80
          && m().template.data.vaga is string
          && m().template.data.vaga.size() >= 1 && m().template.data.vaga.size() <= 120;
      }
      // (a) email 1: id == id da candidatura; ela existe (no batch ou ja gravada)
      // e o to e o email dela. Sem cap: e a porta do envio anonimo do site.
      function criaRecebida() {
        return moldeOk('candidatura-recebida')
          && existsAfter(/databases/$(database)/documents/candidaturas/$(mailId))
          && m().to == getAfter(/databases/$(database)/documents/candidaturas/$(mailId)).data.email;
      }
      // (b) email de status: so a GP; id == '<candidaturaId>-<status>'.
      function criaStatus(status) {
        let candId = mailId.replace('-' + status + '$', '');
        return gpCand()
          && moldeOk('candidatura-' + status)
          && mailId == candId + '-' + status
          && exists(/databases/$(database)/documents/candidaturas/$(candId))
          && m().to == get(/databases/$(database)/documents/candidaturas/$(candId)).data.email;
      }
      allow create: if criaRecebida()
        || criaStatus('em-analise')
        || criaStatus('aprovada')
        || criaStatus('nao-seguiu');
      allow read, update, delete: if false;
    }

    // ----- emailTemplates (moldes da extensao Trigger Email) -----
    // Leitura: qualquer autenticado (os moldes nao tem segredo; o app pode
    // exibi-los pra GP). Escrita: SO admin, com shape sano (subject/text/html
    // strings, caps generosos). O seed e idempotente pelo cliente admin (setDoc
    // = create/update). Delete fica no default-deny: molde e conteudo que a
    // extensao consome; nao ha fluxo de exclusao pelo cliente (Admin SDK/console
    // resolvem, se um dia precisar).
    match /emailTemplates/{tid} {
      allow read: if isAuthed();
      allow create, update: if isAdmin()
        && request.resource.data.keys().hasOnly(['subject', 'text', 'html'])
        && request.resource.data.subject is string && request.resource.data.subject.size() <= 200
        && request.resource.data.text is string && request.resource.data.text.size() <= 10000
        && request.resource.data.html is string && request.resource.data.html.size() <= 10000;
    }

    // ============================================================
    // FILA DE WHATSAPP (caminho solo Meta Cloud API, 2026-07-22). Espelho
    // ESTRUTURAL da /mail: uma Cloud Function (proxima etapa) consome /waMsg via
    // Admin SDK (IGNORA estas rules), resolve o template Meta PINADO e envia
    // pela Graph API. As rules governam SO os clientes; o desenho e anti-spam
    // estrutural: ninguem usa o numero da Fiobras pra mandar WhatsApp fora do
    // funil de candidaturas. A propriedade que as duas portas garantem: uma
    // mensagem so pode ir pro PROPRIO telefone de uma candidatura REAL, com
    // template PINADO, e no maximo 1 vez por (candidatura, template) -- o doc id
    // e deterministico e create-only, entao repetir vira update, que NEGA.
    //   (a) RECEBIDA (anonimo, template 'candidatura_recebida'): sai junto do
    //       envio da candidatura, no MESMO batch; o id do waMsg E o id da
    //       candidatura e o para tem que ser o TELEFONE dela (getAfter ve o irmao
    //       criado junto). O existsAfter tambem casa candidatura pre-existente, e
    //       ta OK: o para segue travado no telefone dela e o id trava 1 recebida
    //       por candidatura, entao nao ha amplificacao (nunca WhatsApp pra numero
    //       arbitrario nem repetido).
    //   (b) STATUS (pela GP, cap vagas.gerenciar): a candidatura JA existe; o id
    //       do waMsg e '<candidaturaId>-<status>' (status in
    //       em_analise/aprovada/nao_seguiu, tokens Meta em UNDERSCORE, iguais aos
    //       do nome do template) e o para tem que ser o telefone dela. O
    //       candidaturaId sai do proprio waId tirando o sufixo '-<status>'
    //       (replace ancorado em $) e e RE-CONFIRMADO por concatenacao
    //       (waId == candId + '-' + status): strip+concat e airtight mesmo que o
    //       telefone/email da candidatura contenha o texto de um status. Cada
    //       status e um ramo EXPLICITO (nao deriva string de template): lixo em
    //       template cai fora dos 3 e NEGA.
    //   READ/UPDATE/DELETE de cliente: false. O doc ganha PII do candidato (para)
    //   e status de envio escrito pela function; so a function (Admin SDK) mexe.
    // ============================================================
    match /waMsg/{waId} {
      function gpCand() { return isAdmin() || temCap('vagas.gerenciar', isRH()); }
      function w() { return request.resource.data; }
      // params e so DISPLAY (primeiro nome do candidato = {{1}}, titulo da vaga =
      // {{2}} do template Meta): shape-only, strings sanas. O anti-spam vem do
      // para travado no telefone da candidatura + do template pinado + do id
      // deterministico, nao deste conteudo. candidaturaId e um PONTEIRO explicito
      // pra function, amarrado ao id resolvido (== waId na recebida, == candId no
      // status); em == request.time (mesmo carimbo do irmao candidatura no batch).
      function shapeOk(template, candId) {
        return w().keys().hasOnly(['para', 'template', 'params', 'em', 'candidaturaId'])
          && w().para is string
          && w().template == template
          && w().candidaturaId == candId
          && w().em == request.time
          && w().params is map
          && w().params.keys().hasOnly(['nome', 'vaga'])
          && w().params.nome is string
          && w().params.nome.size() >= 1 && w().params.nome.size() <= 80
          && w().params.vaga is string
          && w().params.vaga.size() >= 1 && w().params.vaga.size() <= 120;
      }
      // (a) recebida: waId == id da candidatura; ela existe (no batch ou ja
      // gravada) e o para e o telefone dela. Sem cap: e a porta do envio
      // anonimo do site.
      function criaRecebida() {
        return shapeOk('candidatura_recebida', waId)
          && existsAfter(/databases/$(database)/documents/candidaturas/$(waId))
          && w().para == getAfter(/databases/$(database)/documents/candidaturas/$(waId)).data.telefone;
      }
      // (b) status: so a GP; waId == '<candidaturaId>-<status>'.
      function criaStatus(status) {
        let candId = waId.replace('-' + status + '$', '');
        return gpCand()
          && shapeOk('candidatura_' + status, candId)
          && waId == candId + '-' + status
          && exists(/databases/$(database)/documents/candidaturas/$(candId))
          && w().para == get(/databases/$(database)/documents/candidaturas/$(candId)).data.telefone;
      }
      allow create: if criaRecebida()
        || criaStatus('em_analise')
        || criaStatus('aprovada')
        || criaStatus('nao_seguiu');
      allow read, update, delete: if false;
    }
  }
}
