rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ----- Helpers -----

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function isAuthed() {
      return request.auth != null;
    }
    function isAdmin() {
      return isAuthed() && userDoc().role == 'admin';
    }
    function isRH() {
      return isAuthed() && userDoc().role == 'rh';
    }
    function isLider() {
      return isAuthed() && userDoc().role == 'lider';
    }
    function isSupervisor() {
      return isAuthed() && userDoc().role == 'supervisor';
    }
    // ----- Portal do Colaborador (Fundação SELF) -----
    function isColaborador() {
      return isAuthed() && userDoc().role == 'colaborador';
    }
    // Vínculo SELF: funcionarioId gravado em users/{uid}. Ausente => '' (fail-safe: nunca casa
    // com id real => leitura negada). Defense-in-depth: a UI já filtra; isto é a rede de baixo.
    function meuFuncionarioId() {
      return isColaborador() && ('funcionarioId' in userDoc()) && userDoc().funcionarioId is string
        ? userDoc().funcionarioId : '';
    }
    function euSouODono(funcId) {
      return meuFuncionarioId() != '' && funcId == meuFuncionarioId();
    }
    function supervisorVe(funcId) {
      return isSupervisor()
        && userDoc().funcionariosVisiveis is list
        && userDoc().funcionariosVisiveis.hasAny([funcId]);
    }
    // Supervisor por TURNO (automação): cobre turnos inteiros (ex.: Aldo = 1,2,3).
    // O escopo efetivo do supervisor é supervisorVe (avulsos) OU supervisorVeTurno.
    function supervisorVeTurno(turno) {
      return isSupervisor()
        && userDoc().turnosVisiveis is list
        && userDoc().turnosVisiveis.hasAny([turno]);
    }
    function liderDoMesmoTurno(turno) {
      return isLider() && userDoc().turno == turno;
    }
    // READ amplo: supervisor lê todas as ocorrências (a UI filtra pela lista
    // dele). O escopo estrito (supervisorVe) é aplicado só no WRITE/conferir.
    function podeVerOcorrencia(doc) {
      return isAdmin() || isRH()
        || liderDoMesmoTurno(doc.funcionarioTurno)
        || isSupervisor();
    }

    // ----- Permissões data-driven (matriz editável) -----
    // Lê /config/permissoes (mapa { papel: { capability: valor } }). Se o doc
    // não existir OU não tiver a (papel, capability), cai no `fallback` — que é
    // SEMPRE a regra hardcoded de hoje. Logo: doc ausente/parcial = comportamento
    // idêntico ao atual. Admin é tratado à parte (sempre liberado) por quem chama.
    // valores "ligados": true | 'turno' | 'atrib'.
    function permDoc() {
      return exists(/databases/$(database)/documents/config/permissoes)
        ? get(/databases/$(database)/documents/config/permissoes).data
        : {};
    }
    // ATENCAO (invariante, Fable 2026-07-06): o retorno e BOOLEANO. Os valores 'turno' e
    // 'atrib' da matriz viram apenas "ligado"; o ESCOPO (filtrar por turno do lider, por
    // funcionariosVisiveis do supervisor) e SEMPRE aplicado hardcoded no match que usa a
    // cap, NUNCA inferido daqui. Cap scoped nova sem esse filtro no match = furo de acesso.
    function temCap(cap, fallback) {
      let m = permDoc();
      let role = userDoc().role;
      return isAuthed() && (
        (role in m && cap in m[role])
          ? (m[role][cap] == true || m[role][cap] == 'turno' || m[role][cap] == 'atrib')
          : fallback
      );
    }

    // ----- Pacote Gestor: segmentação (comunicados + documentos institucionais) -----
    // Colaborador casa com o segmento? 'todos' sempre; 'turno' por users.turno (canônico:
    // number 1|2|3 OU string 'geral'); 'setor' por users.setor denormalizado.
    // Ausência/null/tipo errado => false (fail-safe: nega). userDoc() é avaliado 1x e
    // passado como argumento (1 get por avaliação, conforme objetivo de custo).
    // DEPENDÊNCIA DE DADOS: users/{uid}.turno e .setor são denormalizados pelo pipeline
    // (sync-colaborador-users.mjs do WKRADAR). Até lá, só 'todos' resolve; turno/setor negam.
    function casaTurno(seg, u) {
      return ('turno' in u)
          && (u.turno is number || u.turno is string)
          && seg.valores.hasAny([u.turno]);
    }
    function casaSetor(seg, u) {
      return ('setor' in u)
          && u.setor is string
          && seg.valores.hasAny([u.setor]);
    }
    function casaSegmento(seg) {
      return seg.tipo == 'todos'
        || (seg.tipo == 'turno' && casaTurno(seg, userDoc()))
        || (seg.tipo == 'setor' && casaSetor(seg, userDoc()));
    }
    // institucional por segmento OU pessoal por dono (SELF)
    function podeVerDoc(d) {
      return (d.escopo == 'institucional' && casaSegmento(d.segmento))
          || (d.escopo == 'pessoal' && d.funcionarioId == meuFuncionarioId());
    }

    // ----- config (matriz de permissões + futuras configs do sistema) -----
    // Leitura: qualquer autenticado (o app monta o can() a partir daqui; sem
    // segredos). Escrita: só admin (gerencia a matriz).
    match /config/{doc} {
      allow read: if isAuthed();
      allow write: if isAdmin();
    }

    // ----- users -----
    // Admin lê todos; user lê só o próprio doc.
    // Admin (ou quem tiver sistema.usuarios) cria/deleta/edita qualquer campo.
    // O próprio user pode atualizar APENAS o campo fotoBase64 (foto de perfil)
    // — sem poder mexer em role, turno, ativo.
    match /users/{uid} {
      // Gestores leem o diretório inteiro (presença/Auditoria resolvem nome/papel/foto
      // por uid) — INALTERADO. Colaborador lê SÓ o próprio doc (sem diretório nesta fase).
      allow read: if isAdmin() || isRH() || isLider() || isSupervisor()
                  || (isColaborador() && request.auth.uid == uid);
      allow create, delete: if isAdmin() || temCap('sistema.usuarios', false);
      // Self-update: além de fotoBase64, o colaborador zera precisaTrocarSenha (troca no 1º acesso).
      // Continua impedindo mexer em role/turno/ativo/funcionarioId.
      allow update: if isAdmin() || temCap('sistema.usuarios', false) || (
        request.auth.uid == uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['fotoBase64', 'precisaTrocarSenha'])
      );
    }

    // ----- funcionarios -----
    match /funcionarios/{id} {
      // Gestores leem amplo (INALTERADO); colaborador só o próprio funcionário (escopo SELF).
      allow read: if isAdmin() || isRH() || isLider() || isSupervisor()
                  || (isColaborador() && euSouODono(id));
      allow create, update, delete: if isAdmin() || temCap('func.editar', isRH());
    }

    // ----- tipos (motivos customizados criados pela equipe) -----
    // Todos logados leem (pra popular o dropdown). Quem tem sistema.config edita.
    match /tipos/{id} {
      allow read: if isAuthed();
      allow create, update, delete: if isAdmin() || temCap('sistema.config', isRH());
    }

    // ----- acoes (ações customizadas — encaminhamento pelo líder) -----
    match /acoes/{id} {
      allow read: if isAuthed();
      allow create, update, delete: if isAdmin() || temCap('sistema.config', isRH());
    }

    // ----- obrigacoes (checklist recorrente do GH) -----
    // Todos logados leem (card/tela gated na UI por obrigacoes.gerenciar; sem
    // segredos). Escrita (cadastrar/editar/marcar conclusão): GH/admin.
    match /obrigacoes/{id} {
      allow read: if isAuthed();
      allow create, update, delete: if isAdmin() || temCap('obrigacoes.gerenciar', isRH());
    }

    // ----- bancoHoras (saldo de horas por funcionário · denormalizado por doc) -----
    // Líder lê apenas docs do próprio turno; supervisor lê amplo (UI filtra).
    // Escrita: pipeline RH (servidor) ou quem tiver bancoHoras.importar.
    match /bancoHoras/{funcionarioId} {
      allow read: if isAdmin() || isRH()
                  || (isLider() && resource.data.funcionarioTurno == userDoc().turno)
                  || isSupervisor();
      allow create, update, delete: if isAdmin() || temCap('bancoHoras.importar', isRH());
    }

    // ----- pj (controle de prestadores de serviço) -----
    // ver/editar/excluir controlados pela matriz (fallback = admin/RH de hoje).
    // Reajuste é um update do doc pj → coberto por pj.editar.
    match /pj/{id} {
      allow read: if isAdmin() || temCap('pj.ver', isRH());
      allow create, update: if isAdmin() || temCap('pj.editar', isRH());
      allow delete: if isAdmin() || temCap('pj.excluir', isRH());
    }

    // ----- auditoria (log global IMUTÁVEL) -----
    // Admin/quem tem auditoria.ver leem e criam; ninguém edita/apaga.
    match /auditoria/{id} {
      allow read: if isAdmin() || temCap('auditoria.ver', isRH());
      allow create: if (isAdmin() || temCap('auditoria.ver', isRH()))
        && request.resource.data.por == request.auth.uid
        && request.resource.data.acao is string
        && request.resource.data.acao.size() <= 200;
      allow update, delete: if false;
    }

    // ----- eventos (log de auditoria de TODO usuário · self-write append-only) -----
    // Cada usuário grava SÓ os PRÓPRIOS eventos (por == uid). Leitura só p/ auditoria.ver.
    // Append-only (sem update/delete). Destrava login de qualquer papel + ciência/leitura/assinatura
    // do colaborador numa fonte só, sem afrouxar /auditoria. Client-side/auto-relato: é histórico
    // interno, NÃO prova jurídica (anti-fraude server-side fica pra Cloud Function no futuro).
    // Campos limitados; 'alvo' neutro (quem chama não manda conteúdo sensível).
    match /eventos/{id} {
      allow read: if isAdmin() || temCap('auditoria.ver', isRH());
      allow create: if isAuthed()
        && request.resource.data.por == request.auth.uid
        && request.resource.data.em == request.time
        && request.resource.data.tipo is string
        && request.resource.data.tipo.size() <= 40
        && request.resource.data.acao is string
        && request.resource.data.acao.size() > 0
        && request.resource.data.acao.size() <= 200
        && request.resource.data.keys().hasOnly(['por', 'porNome', 'porRole', 'tipo', 'acao', 'alvo', 'em'])
        && (!('alvo' in request.resource.data) || (request.resource.data.alvo is string && request.resource.data.alvo.size() <= 300))
        && (!('porNome' in request.resource.data) || (request.resource.data.porNome is string && request.resource.data.porNome.size() <= 120))
        && (!('porRole' in request.resource.data) || (request.resource.data.porRole is string && request.resource.data.porRole.size() <= 40));
      allow update, delete: if false;
    }

    // ----- presence (quem está online agora) -----
    // So GESTOR escreve (o portal do colaborador nunca liga presenca, gate ehColab no
    // firebase.js) e o role gravado tem que ser o REAL do users/{uid} (antes validava so o
    // payload, entao qualquer autenticado se pintava de 'admin' no painel · Fable 2026-07-06).
    match /presence/{uid} {
      allow read: if isAuthed();
      allow create, update: if isAuthed() && request.auth.uid == uid
        && (isAdmin() || isRH() || isLider() || isSupervisor())
        && request.resource.data.role == userDoc().role
        && request.resource.data.nome is string
        && request.resource.data.nome.size() <= 100;
      allow delete: if isAuthed() && request.auth.uid == uid;
    }

    // ----- ocorrencias -----
    match /ocorrencias/{id} {
      allow read: if podeVerOcorrencia(resource.data)
        || (isColaborador() && euSouODono(resource.data.funcionarioId)); // colaborador vê só as próprias

      // Criar: quem tem ocorrencias.criar (fallback = RH de hoje) ou admin.
      allow create: if (isAdmin() || temCap('ocorrencias.criar', isRH()))
        && request.resource.data.criadoPor == request.auth.uid
        && request.resource.data.acao == null
        && request.resource.data.dataConferencia == null
        && request.resource.data.funcionarioId is string
        && request.resource.data.funcionarioTurno in [1, 2, 3, 'geral']
        && request.resource.data.tipo is string
        && request.resource.data.horario is string;

      // Update: admin sempre; RH lança/edita obs (cap ocorrencias.lancar);
      // líder/supervisor conferem no seu escopo (cap ocorrencias.conferir).
      // Fallbacks preservam exatamente o comportamento atual.
      allow update: if
        isAdmin()
        // GH edita observação SEMPRE (não depende do toggle de lançamento).
        || (isRH() && rhEditaObs())
        // GH marca/desfaz lançamento → gated pelo toggle ocorrencias.lancar.
        || (isRH() && temCap('ocorrencias.lancar', isRH()) && rhLanca())
        || (temCap('ocorrencias.conferir', isLider())
            && liderDoMesmoTurno(resource.data.funcionarioTurno)
            && podeConferirOuAtualizarObs())
        || (temCap('ocorrencias.conferir', isSupervisor())
            && isSupervisor()
            && (supervisorVe(resource.data.funcionarioId)
                || ('funcionarioTurno' in resource.data && supervisorVeTurno(resource.data.funcionarioTurno)))
            && podeConferirOuAtualizarObs())
        // Soft delete pra auditoria (2026-07-09): quem tem a cap de excluir MARCA a
        // flag (excluida/Em/Por) ou a LIMPA (restaurar). Estritamente menos poder que
        // o delete fisico abaixo, que segue permitido mas SAI do fluxo normal do app
        // (a exclusao da UI vira soft; o conteudo fica pra aba Excluidas).
        || ((isAdmin() || temCap('ocorrencias.excluir', isRH()))
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['excluida', 'excluidaEm', 'excluidaPor']));

      allow delete: if isAdmin() || temCap('ocorrencias.excluir', isRH());
    }

    // ----- banco-horas-saldos -----
    // Snapshot rico com CPF/PIS · SEMPRE só admin + RH (dado sensível, fixo).
    match /banco-horas-saldos/{funcId} {
      allow read: if isAdmin() || isRH();
      allow write: if false;
    }

    // ----- banco-horas -----
    match /banco-horas/{docId} {
      allow read: if isAdmin() || isRH();
      allow write: if false;
    }

    // ----- banco-horas-self (saldo + espelho SELF · SEM PII · doc por código) -----
    // Populado pelo pipeline (servidor). Colaborador lê SÓ o próprio (codigo == seu codigo);
    // admin/RH leem qualquer um. O GESTOR (Espelho de ponto do portal) lê os liderados:
    // líder pelo funcionarioTurno do doc, supervisor pelo funcionarioId do doc — ambos
    // DENORMALIZADOS no doc pelo pipeline. O guard 'campo in resource.data' fecha o buraco
    // do doc legado (sem o campo): nunca casa antes do pipeline gravar. string() coage o codigo.
    match /banco-horas-self/{codigo} {
      allow read: if isAdmin() || isRH()
                  || (isColaborador() && 'codigo' in userDoc() && string(userDoc().codigo) == codigo)
                  || (isLider() && 'funcionarioTurno' in resource.data && resource.data.funcionarioTurno == userDoc().turno)
                  || (isSupervisor() && 'funcionarioId' in resource.data && supervisorVe(resource.data.funcionarioId))
                  || (isSupervisor() && 'funcionarioTurno' in resource.data && supervisorVeTurno(resource.data.funcionarioTurno));
      allow write: if false;
    }

    // ----- recibos (recibo de pagamento / cartão ponto por funcionário · PDF no Storage) -----
    // METADADOS aqui; o PDF vive no Firebase Storage (recibos/{funcionarioId}/{competencia}.pdf).
    // Gerado pelo GP (import + quebra por CPF). Colaborador lê SÓ o dele (funcionarioId ==
    // meuFuncionarioId()); admin/RH gerenciam (cap recibos.gerenciar, fallback isRH). Campos de
    // origem (criadoEm/criadoPor/funcionarioId/competencia) imutáveis no update; delete só admin.
    // A assinatura N1 (Fase B) entrará numa subcoleção assinaturas/{uid} create-only (ainda não).
    match /recibos/{id} {
      allow read: if isAdmin() || temCap('recibos.gerenciar', isRH())
                  || (isColaborador() && resource.data.funcionarioId == meuFuncionarioId());

      allow create: if (isAdmin() || temCap('recibos.gerenciar', isRH()))
        && request.resource.data.criadoPor == request.auth.uid
        && request.resource.data.criadoEm == request.time
        && request.resource.data.funcionarioId is string
        && request.resource.data.competencia is string
        && request.resource.data.tipo is string;

      allow update: if (isAdmin() || temCap('recibos.gerenciar', isRH()))
        && request.resource.data.criadoEm == resource.data.criadoEm
        && request.resource.data.criadoPor == resource.data.criadoPor
        && request.resource.data.funcionarioId == resource.data.funcionarioId
        && request.resource.data.competencia == resource.data.competencia;

      allow delete: if isAdmin();

      // arquivo/{docId}: o PDF (base64) mora AQUI, separado dos metadados — a lista do
      // gestor lê só o pai (leve) e o arquivo é buscado sob demanda ao abrir. funcionarioId
      // DENORMALIZADO no subdoc (evita get() no pai a cada LEITURA). No CREATE, o subdoc é
      // AMARRADO ao pai: precisa existir (existsAfter cobre o batch pai+filho junto) e o
      // funcionarioId tem que bater com o do pai — sem arquivo órfão nem trocado. Payload
      // fechado (hasOnly). Imutável: substituição = admin exclui o lote e o GP reimporta.
      // delete só admin é DECISÃO (espelha documentos): RH gerencia create/update; destruir, não.
      match /arquivo/{docId} {
        allow read: if isAdmin() || temCap('recibos.gerenciar', isRH())
                    || (isColaborador() && resource.data.funcionarioId == meuFuncionarioId());
        allow create: if (isAdmin() || temCap('recibos.gerenciar', isRH()))
                      && request.resource.data.keys().hasOnly(['funcionarioId', 'base64'])
                      && request.resource.data.funcionarioId is string
                      && existsAfter(/databases/$(database)/documents/recibos/$(id))
                      && request.resource.data.funcionarioId
                           == getAfter(/databases/$(database)/documents/recibos/$(id)).data.funcionarioId;
        allow update: if false;
        allow delete: if isAdmin();
      }

      // assinaturas/{uid}: a trilha da Fase B — create-only pelo DONO do recibo, com
      // geolocalização EXIGIDA (decisão do William: sem local, não assina). Campos
      // fechados; funcionarioId tem que bater com o do recibo pai (get); em = hora do
      // servidor. Reassinar não existe: update/delete negados (2º set vira update => nega).
      // Gestor NÃO assina pelo colaborador. arquivoPath aponta a versão carimbada no Storage.
      match /assinaturas/{uid} {
        allow read: if isAdmin() || temCap('recibos.gerenciar', isRH())
                    || (isAuthed() && request.auth.uid == uid);
        allow create: if isColaborador()
          && request.auth.uid == uid
          && request.resource.data.uid == uid
          && request.resource.data.keys().hasOnly(['uid', 'funcionarioId', 'em', 'userAgent', 'geo', 'hashSha256', 'aceiteTexto', 'arquivoPath'])
          && request.resource.data.em == request.time
          && request.resource.data.geo.lat is number
          && request.resource.data.geo.lng is number
          && euSouODono(request.resource.data.funcionarioId)
          && request.resource.data.funcionarioId
               == get(/databases/$(database)/documents/recibos/$(id)).data.funcionarioId;
        allow update, delete: if false;
      }
    }

    // ----- pipeline-rh (estrutura cur/hist · espelho do Comercial · SEM PII) -----
    match /pipeline-rh/{docId} {
      allow read: if isAdmin() || isRH();
      allow write: if false;
    }

    // ----- identificacao (diretório código→{nome, cpf} de TODOS os ativos · PII) -----
    // Fonte do casamento CPF→funcionário no import de recibos: cobre quem NÃO tem banco
    // de horas (ex.: menor aprendiz, que nunca entra em banco-horas-saldos). Populada
    // pelo pipeline (WKRADAR, Admin SDK). Leitura só admin/RH (LGPD); ninguém escreve
    // pelo cliente. O CPF daqui NUNCA persiste nos docs do colaborador.
    match /identificacao/{codigo} {
      allow read: if isAdmin() || isRH();
      allow write: if false;
    }

    // ===== Pacote Gestor (ADITIVO) — Comunicados + Documentos institucionais =====

    // ----- comunicados (canal oficial 1→N originado no gestor) -----
    // Leitura: gestor com a cap vê todos; colaborador vê só ativos do seu segmento.
    // Escrita: gated por comunicados.gerenciar (fallback RH). publicadoEm é server-time
    // no create e imutável no update; autorUid imutável. Soft-delete (ativo=false) é o
    // caminho normal; delete físico só admin.
    match /comunicados/{id} {
      allow read: if isAdmin() || temCap('comunicados.gerenciar', isRH())
                  || (isColaborador()
                      && resource.data.ativo == true
                      && casaSegmento(resource.data.segmento));

      allow create: if (isAdmin() || temCap('comunicados.gerenciar', isRH()))
                    && request.resource.data.autorUid == request.auth.uid
                    && request.resource.data.publicadoEm == request.time
                    && request.resource.data.ativo is bool;

      allow update: if (isAdmin() || temCap('comunicados.gerenciar', isRH()))
                    && request.resource.data.publicadoEm == resource.data.publicadoEm
                    && request.resource.data.autorUid == resource.data.autorUid;

      allow delete: if isAdmin();

      // leituras/{uid}: 1 por pessoa (self-write), amarrada ao segmento do pai
      // (não infla X/Y com quem não vê o doc). Append-only.
      match /leituras/{uid} {
        allow read: if isAdmin() || temCap('comunicados.gerenciar', isRH())
                    || (isAuthed() && request.auth.uid == uid);
        allow create: if isAuthed()
                    && request.auth.uid == uid
                    && request.resource.data.uid == uid
                    && request.resource.data.keys().hasOnly(['uid', 'funcionarioId', 'confirmado', 'em', 'userAgent'])
                    && (isAdmin() || temCap('comunicados.gerenciar', isRH())
                        || casaSegmento(get(/databases/$(database)/documents/comunicados/$(id)).data.segmento));
        allow update, delete: if false;
      }
    }

    // ----- documentos (institucional por segmento + pessoal por dono coexistindo) -----
    // institucional = sem funcionarioId, com segmento; pessoal = com funcionarioId, sem segmento.
    // criadoEm/criadoPor/escopo imutáveis. Em doc publicado+exigeAssinatura, segmento/anexo
    // imutáveis por update direto (CORREÇÃO 4): a ÚNICA forma de trocar anexo é novaVersao
    // (versao incrementa em 1). Subcoleções amarradas ao pai; versaoAssinada == versao atual.
    //
    // NÍVEL DE CONFIRMAÇÃO (ADITIVO): campo `confirmacao` em ['nenhuma','aceite','assinatura'].
    // O legado (exigeAssinatura, sem confirmacao) segue valendo: nível efetivo derivado só
    // pela UI/backend; a rule apenas RESTRINGE o valor de confirmacao quando presente e trava
    // que o colaborador o altere (não pode escrever no doc pai de qualquer forma). Só quem já
    // pode criar/editar documentos grava confirmacao (mesma condição gated do match).
    match /documentos/{id} {
      allow read: if isAdmin() || temCap('documentos.gerenciar', isRH())
        || (isColaborador() && resource.data.status == 'publicado' && (
             (resource.data.escopo == 'institucional' && casaSegmento(resource.data.segmento))
             || (resource.data.escopo == 'pessoal' && resource.data.funcionarioId == meuFuncionarioId())
           ));

      allow create: if (isAdmin() || temCap('documentos.gerenciar', isRH()))
        && request.resource.data.criadoPor == request.auth.uid
        && request.resource.data.criadoEm == request.time
        && (!('confirmacao' in request.resource.data)
            || request.resource.data.confirmacao in ['nenhuma', 'aceite', 'assinatura'])
        && (
          (request.resource.data.escopo == 'institucional'
            && !('funcionarioId' in request.resource.data))
          || (request.resource.data.escopo == 'pessoal'
            && request.resource.data.funcionarioId is string)
        );

      allow update: if (isAdmin() || temCap('documentos.gerenciar', isRH()))
        && request.resource.data.criadoEm == resource.data.criadoEm
        && request.resource.data.criadoPor == resource.data.criadoPor
        && request.resource.data.escopo == resource.data.escopo
        && (!('confirmacao' in request.resource.data)
            || request.resource.data.confirmacao in ['nenhuma', 'aceite', 'assinatura'])
        && (
          // só trava quando já publicado E exige assinatura; senão update livre (gated)
          !(resource.data.status == 'publicado' && resource.data.exigeAssinatura == true)
          || (
            request.resource.data.segmento == resource.data.segmento
            && (
              // anexo imutável, EXCETO quando é uma novaVersao (versao incrementa em 1)
              request.resource.data.anexo == resource.data.anexo
              || request.resource.data.versao == resource.data.versao + 1
            )
          )
        );

      allow delete: if isAdmin();

      // aceites/{uid}: NÍVEL 'aceite' — o "Li e aceito" simples (sem senha/local/carimbo).
      // Create-only pelo colaborador DONO (uid == auth.uid). Payload mínimo e fechado;
      // em == hora do servidor; amarrado ao segmento/dono do pai. Append-only (imutável).
      // Separado de 'assinaturas' de propósito: aqui NÃO há geo nem hash de arquivo.
      match /aceites/{uid} {
        allow read: if isAdmin() || temCap('documentos.gerenciar', isRH())
                    || (isAuthed() && request.auth.uid == uid);
        allow create: if isAuthed()
                    && request.auth.uid == uid
                    && request.resource.data.uid == uid
                    && request.resource.data.keys().hasOnly(['uid', 'em', 'userAgent', 'versao'])
                    && request.resource.data.em == request.time
                    && (isAdmin() || temCap('documentos.gerenciar', isRH())
                        || podeVerDoc(get(/databases/$(database)/documents/documentos/$(id)).data));
        allow update, delete: if false;
      }

      // assinaturas/{uid}: create-only pelo DONO, versaoAssinada == versao atual do pai
      // (CORREÇÃO 7); amarrada ao segmento/dono do pai (CORREÇÃO 6). DUAS formas aceitas
      // (aditivo, retrocompatível):
      //  (a) LEGADO N1: uid/funcionarioId/versaoAssinada/hashSha256/aceiteTexto/em/userAgent
      //      — o "Li e aceito" com hash do anexo, SEM geo (fluxo já no ar).
      //  (b) NÍVEL 'assinatura' CARIMBADO (espelha recibos): + geo.lat/lng number e
      //      arquivoPath — senha+localização+carimbo no arquivo. em == hora do servidor.
      // Em ambas: em == request.time, versaoAssinada number == versao do pai. Append-only.
      match /assinaturas/{uid} {
        allow read: if isAdmin() || temCap('documentos.gerenciar', isRH())
                    || (isAuthed() && request.auth.uid == uid);
        allow create: if isAuthed()
                    && request.auth.uid == uid
                    && request.resource.data.uid == uid
                    && request.resource.data.em == request.time
                    && request.resource.data.versaoAssinada is number
                    && request.resource.data.versaoAssinada
                         == get(/databases/$(database)/documents/documentos/$(id)).data.versao
                    && (
                      // (a) legado N1 (sem geo)
                      request.resource.data.keys().hasOnly(['uid', 'funcionarioId', 'versaoAssinada', 'hashSha256', 'aceiteTexto', 'em', 'userAgent'])
                      // (b) carimbo com geo (espelha recibos)
                      || (
                        request.resource.data.keys().hasOnly(['uid', 'funcionarioId', 'versaoAssinada', 'hashSha256', 'aceiteTexto', 'em', 'userAgent', 'geo', 'arquivoPath'])
                        && request.resource.data.geo.lat is number
                        && request.resource.data.geo.lng is number
                        && request.resource.data.arquivoPath is string
                      )
                    )
                    && (isAdmin() || temCap('documentos.gerenciar', isRH())
                        || podeVerDoc(get(/databases/$(database)/documents/documentos/$(id)).data));
        allow update, delete: if false;
      }

      // leituras/{uid}: visualização sem assinatura (docs exigeAssinatura=false). Append-only.
      match /leituras/{uid} {
        allow read: if isAdmin() || temCap('documentos.gerenciar', isRH())
                    || (isAuthed() && request.auth.uid == uid);
        allow create: if isAuthed() && request.auth.uid == uid
                    && request.resource.data.uid == uid
                    && request.resource.data.keys().hasOnly(['uid', 'funcionarioId', 'confirmado', 'em', 'userAgent'])
                    && (isAdmin() || temCap('documentos.gerenciar', isRH())
                        || podeVerDoc(get(/databases/$(database)/documents/documentos/$(id)).data));
        allow update, delete: if false;
      }
    }

    // ===== Termo de adesao a assinatura eletronica (ciencia no 1o acesso) =====
    // Um registro por pessoa (id = uid), IMUTAVEL: a ciencia do termo de adesao ao meio
    // eletronico, dada no primeiro acesso (depois de criar a senha). O app so mostra o
    // termo se este doc NAO existir. Ler: o proprio dono E o gestor (auditoria/LGPD).
    // ponytail: se o termo mudar de versao um dia, migrar pra id {uid}__{versao} pra
    // permitir readesao; hoje e create-only por id fixo (uma ciencia por pessoa).
    match /termoAdesao/{uid} {
      allow read: if isAuthed() && (request.auth.uid == uid || isAdmin() || temCap('documentos.gerenciar', isRH()));
      allow create: if isAuthed()
                  && request.auth.uid == uid
                  && request.resource.data.uid == uid
                  && request.resource.data.keys().hasOnly(['uid', 'funcionarioId', 'versao', 'hashSha256', 'em', 'userAgent'])
                  && euSouODono(request.resource.data.funcionarioId)
                  && request.resource.data.versao == '2026-07-v1'
                  && request.resource.data.hashSha256 == '931a476238918cb6e771e30238b307403606b224b1b32745ce21f6197e16c805'
                  && request.resource.data.userAgent is string
                  && request.resource.data.em == request.time;
      allow update, delete: if false;
    }
    // versao + hashSha256 CRAVADOS na regra (Fable): a versao e o sha256 do texto canonico
    // congelado (docs/termo-adesao-2026-07-v1.txt, LF) ancoram QUAL texto foi aceito, fora do
    // controle unilateral da empresa. Bump de versao = novo hash aqui + readesao.

    // ===== Mural de aniversario (celebracao social entre colegas) =====
    // postId "aniv-{slug}-{ano}" (aniversario) OU "bv-{slug}-{anoAdmissao}" (boas-vindas
    // a recem-contratados, 2026-07-09; mesmo sistema de reacao, so muda o tipo). NAO exige
    // doc pai (subcolecoes valem sem ele); por isso o proprio /muralAniversario/{postId}
    // nunca e escrito pelo cliente.
    // Conteudo entre colegas: reacao (coracao no aniversario, bemvindo no bv-; uma por
    // pessoa, toggle) e recado (texto curto, varios por pessoa). Leitura: qualquer
    // autenticado (a festa e compartilhada).
    // Escrita: so como voce mesmo (autorUid/uid == auth.uid). Recado apaga o proprio autor
    // OU gestor (moderacao/LGPD); o autorUid fica gravado como trilha de quem escreveu.
    // Recado append-only; reacao aceita re-set idempotente (mesmo conteudo, anti-spoof
    // intacto) pra 2a tentativa nao virar erro. em == hora do servidor.
    match /muralAniversario/{postId} {
      allow read: if isAuthed();
      allow write: if false; // doc pai nunca e escrito pelo cliente

      match /reacoes/{uid} {
        // Mesma predicado pro create E pro update: reagir de novo com o MESMO
        // conteudo e idempotente (nao erro). Sem isso, o cliente que refaz o
        // set() num doc que ja existe (2a tentativa apos leitura stale em rede
        // ruim) caia em update -> negado -> toast. A igualdade anti-spoof
        // (autorNome == userDoc().nome) segue intacta.
        // Tipo casado com o prefixo do post (disjuncao explicita, padrao da casa):
        // post bv- so aceita 'bemvindo', post de aniversario so aceita 'coracao'.
        // Guard de auto-toque (nao reagir ao proprio post) fica no CLIENTE: o postId
        // chaveia por slug do nome e a regra nao slugifica; o risco residual e so
        // cosmetico (contador do proprio card), sem PII nem perda de dado.
        // ponytail: guard server-side exigiria funcionarioId no postId ou doc pai
        // escrito pelo servidor.
        function reacaoOk() {
          return isAuthed()
              && request.auth.uid == uid
              && request.resource.data.uid == uid
              && request.resource.data.keys().hasOnly(['uid', 'tipo', 'autorNome', 'em'])
              && ((postId.matches('bv-.*') && request.resource.data.tipo == 'bemvindo')
               || (!postId.matches('bv-.*') && request.resource.data.tipo == 'coracao'))
              && request.resource.data.autorNome is string
              && request.resource.data.autorNome.size() <= 80
              && request.resource.data.autorNome == userDoc().nome
              && request.resource.data.em == request.time;
        }
        allow read: if isAuthed();
        allow create: if reacaoOk();
        allow update: if reacaoOk();
        allow delete: if isAuthed() && (request.auth.uid == uid || isAdmin() || isRH());
      }

      match /recados/{recadoId} {
        allow read: if isAuthed();
        allow create: if isAuthed()
                    && request.resource.data.autorUid == request.auth.uid
                    && request.resource.data.keys().hasOnly(['autorUid', 'autorNome', 'texto', 'em'])
                    && request.resource.data.autorNome is string
                    && request.resource.data.autorNome.size() <= 80
                    && request.resource.data.autorNome == userDoc().nome
                    && request.resource.data.texto is string
                    && request.resource.data.texto.size() >= 1
                    && request.resource.data.texto.size() <= 500
                    && request.resource.data.em == request.time;
        allow delete: if isAuthed()
                    && (resource.data.autorUid == request.auth.uid || isAdmin() || isRH());
        allow update: if false;
      }
    }

    // ===== ocorrencias-auto (TESTE / sandbox) =====
    // Ocorrências geradas pelo pipeline da apuração do ponto (WK). Coleção SEPARADA da
    // 'ocorrencias' de produção: zero impacto no fluxo manual. O CONTEÚDO é escrito só pelo
    // servidor (Admin SDK, que ignora estas rules). Do app, admin/RH apenas LÊ e CONFERE:
    // muda status -> 'conferida' e faz APPEND no historico (quem/quando). Sem PII na coleção.
    // Modelo cria-e-nunca-reabre: o cliente só leva status PARA 'conferida', nunca de volta.
    // Fluxo de 2 estagios (RH -> Lider): pipeline cria 'rh_confere'; RH valida (-> 'com_lider')
    // ou dispensa (-> 'dispensada'); lider do TURNO confirma (-> 'confirmada'). Cria-e-nunca-reabre
    // (status novo nunca volta pra 'rh_confere'). Legado: 'aguardando_conferencia' (= RH confere) e
    // 'conferida' (terminal antigo) seguem aceitos durante a transicao.
    match /ocorrencias-auto/{id} {
      // READ amplo pro supervisor (espelha /ocorrencias: podeVerOcorrencia da read amplo ao
      // supervisor e a UI filtra pelo escopo dele na INGESTAO). Sem PII forte nesta colecao;
      // os 4 supervisores ja leem todas as manuais via API. Escopo estrito (supervisorVe/
      // VeTurno) fica no WRITE abaixo. ponytail: se um dia precisar estrito no read, e 1 query
      // == por turno + in chunked de 30 pros funcionariosVisiveis, com merge no cliente.
      allow read: if isAdmin() || isRH()
                  || (isLider() && resource.data.turno == userDoc().turno)
                  || isSupervisor();

      // acao/observacao: a DESTINAÇÃO que o líder escolhe ao conferir (mesma liturgia
      // da ocorrência manual — pedido do William 2026-07-02). Continuam gated pelas
      // mesmas transições de status abaixo.
      // O lock de campos (hasOnly) vive DENTRO de cada ramo: o RH/admin pode CORRIGIR
      // 'tipo' e 'duracaoFmt' junto da transicao (nunca deixa em rh_confere, onde o
      // pipeline reprocessaria e reverteria a correcao); o lider NAO reclassifica, so
      // confirma, entao seu ramo segue travado nos 4 campos originais.
      // 'is list' primeiro (guarda Fable 2026-07-06): sem ele, uma STRING/MAP com size()
      // == +1 passaria e a trilha inteira viraria lixo (perda de dado irreversivel).
      allow update: if request.resource.data.historico is list
        && request.resource.data.historico.size() == resource.data.historico.size() + 1
        && (
          // RH/admin no estagio "RH confere": manda pro lider, dispensa, ou conclui direto.
          // Pode corrigir tipo/duracaoFmt no mesmo update (a transicao tira de rh_confere).
          ( (isAdmin() || temCap('ocorrencias.revisarAuto', isRH()))
            && resource.data.status in ['rh_confere', 'aguardando_conferencia', 'com_lider']
            && request.resource.data.status in ['com_lider', 'dispensada', 'confirmada', 'conferida']
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'historico', 'acao', 'observacao', 'tipo', 'duracaoFmt', 'classificacaoIncerta'])
            // Se a correcao TOCOU o campo, ele tem que continuar string plausivel: barra o
            // delete (o WK nao repoe fora de rh_confere -> seria perda de dado irreversivel)
            // e valor nao-string. Quem nao toca o campo passa igual (aditivo, inclui legado).
            && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['tipo'])
                || (request.resource.data.tipo is string
                    && request.resource.data.tipo.size() >= 1
                    && request.resource.data.tipo.size() <= 80))
            && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['duracaoFmt'])
                || (request.resource.data.duracaoFmt is string
                    && request.resource.data.duracaoFmt.size() >= 1
                    && request.resource.data.duracaoFmt.size() <= 20))
            // A revisao da RH SO PODE ZERAR a incerteza (nunca re-flaga): se tocar o campo,
            // tem que ser == false. "incerto" e afirmacao sobre o estado atual (precisa de
            // humano?); depois que a RH revisou, e nao. motivoIncerteza/historico ficam.
            && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['classificacaoIncerta'])
                || request.resource.data.classificacaoIncerta == false) )
          ||
          // Lider do TURNO confirma o que esta "com o lider" — sem tocar na classificacao.
          ( isLider() && resource.data.turno == userDoc().turno
            && resource.data.status == 'com_lider'
            && request.resource.data.status == 'confirmada'
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'historico', 'acao', 'observacao']) )
          ||
          // Supervisor confirma no ESCOPO (avulsos OU turno) — paridade com o conferir da
          // ocorrencia manual (William 2026-07-08); mesma transicao e mesmos campos do lider.
          ( temCap('ocorrencias.conferir', isSupervisor())
            && isSupervisor()
            && (('funcionarioId' in resource.data && supervisorVe(resource.data.funcionarioId))
                || ('turno' in resource.data && supervisorVeTurno(resource.data.turno)))
            && resource.data.status == 'com_lider'
            && request.resource.data.status == 'confirmada'
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'historico', 'acao', 'observacao']) )
          ||
          // RH/admin LANCA na folha (ou desfaz) uma ja decidida — espelho do fluxo manual
          // (mesma cap ocorrencias.lancar; pedido William 2026-07-08). NAO mexe no status
          // (fora do hasOnly); marcar exige o trio coerente, desfazer zera o trio.
          ( (isAdmin() || temCap('ocorrencias.lancar', isRH()))
            && resource.data.status in ['confirmada', 'conferida']
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lancada', 'lancadoEm', 'lancadoPor', 'historico'])
            && (
              (request.resource.data.lancada == true
                && request.resource.data.lancadoEm is string
                && request.resource.data.lancadoPor == request.auth.uid)
              ||
              (request.resource.data.lancada == false
                && request.resource.data.lancadoEm == null
                && request.resource.data.lancadoPor == null)
            ) )
        );

      // Conteúdo nasce e some só pelo servidor (Admin SDK bypassa rules).
      allow create, delete: if false;
    }

    // ===== monitor/wkradar — saúde do pipeline RH (somente leitura no app) =====
    // Doc gravado pelo servidor (Admin SDK) a cada execução do pipeline. SEM PII (só nomes
    // de arquivo/coleção, horários, contagens). Admin/RH leem; o app nunca escreve.
    match /monitor/{doc} {
      allow read: if isAdmin() || temCap('pipeline.monitor', isRH());
      allow write: if false;
    }

    // ===== disciplinares (advertencia/suspensao) — registro disciplinar SENSIVEL =====
    // Registra: admin/RH. Le: admin/RH, lider do TURNO do funcionario, e o PROPRIO
    // colaborador (so a dele, via funcionarioId). Tem anexo (doc) + ciencia do colaborador
    // (subcolecao self-write, append-only). Delete so admin. Auditoria em /auditoria (create).
    match /disciplinares/{id} {
      allow read: if isAdmin() || isRH()
        || liderDoMesmoTurno(resource.data.funcionarioTurno)
        || (isColaborador() && resource.data.funcionarioId == meuFuncionarioId());

      allow create: if (isAdmin() || isRH())
        && request.resource.data.aplicadoPor == request.auth.uid
        && request.resource.data.criadoEm == request.time
        && request.resource.data.funcionarioId is string
        && request.resource.data.funcionarioId.size() > 0
        && request.resource.data.tipo in ['verbal', 'escrita', 'suspensao'];

      // Edicao restrita (correcao de motivo/descricao/anexo/dias/data) por admin/RH;
      // funcionario/tipo/aplicadoPor/criadoEm sao imutaveis.
      allow update: if (isAdmin() || isRH())
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['motivo', 'descricao', 'anexo', 'dias', 'data', 'editadoEm', 'editadoPor']);

      allow delete: if isAdmin();

      // ciencia/{uid}: o colaborador DONO confirma que leu. Append-only, self-write,
      // amarrada ao dono do registro pai (funcionarioId == meuFuncionarioId).
      match /ciencia/{uid} {
        allow read: if isAdmin() || isRH()
          || liderDoMesmoTurno(get(/databases/$(database)/documents/disciplinares/$(id)).data.funcionarioTurno)
          || (isAuthed() && request.auth.uid == uid);
        allow create: if isAuthed()
          && request.auth.uid == uid
          && request.resource.data.uid == uid
          && request.resource.data.keys().hasOnly(['uid', 'funcionarioId', 'em', 'userAgent'])
          && get(/databases/$(database)/documents/disciplinares/$(id)).data.funcionarioId == meuFuncionarioId();
        allow update, delete: if false;
      }
    }

    // ----- Helpers de atualização -----

    // GH editando só a observação (anotação benigna) — sempre permitido,
    // independe do toggle de lançamento.
    function rhEditaObs() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['observacao', 'historico', 'atualizadoEm']);
    }
    // GH mexendo no status de lançamento — gated pela capability ocorrencias.lancar.
    function rhLanca() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['lancada', 'lancadoEm', 'lancadoPor', 'historico', 'atualizadoEm']);
    }

    function podeConferirOuAtualizarObs() {
      let allowedKeys = ['observacao', 'historico', 'atualizadoEm',
                         'acao', 'dataConferencia', 'conferidoPor'];
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      let mudancasPermitidas = changed.hasOnly(allowedKeys);
      let acaoOk = !changed.hasAny(['acao']) || resource.data.acao == null;
      let dataOk = !changed.hasAny(['dataConferencia']) || resource.data.dataConferencia == null;
      return mudancasPermitidas && acaoOk && dataOk;
    }

    // ============================================================
    // PESQUISA DE CLIMA (2026-07-09) -- anonimato CONFIGURAVEL por pesquisa.
    // Desenho + gate: conselheiro-fable. Anonimato ESTRUTURAL, nao filtro de UI: a
    // resposta anonima e doc ORFAO (sem uid e SEM campo de tempo; ate o createTime
    // via REST e risco, por isso o gestor NUNCA le recibos e so le as cruas
    // depois de ENCERRADA + k>=5). Sem Cloud Functions -> agregacao client-side
    // sobre as cruas depois de encerrada. Cap nova pesquisas.gerenciar e GLOBAL
    // (temCap sem escopo): NUNCA conceder 'turno'/'atrib' pra ela. Residuais
    // (createTime x /eventos, conluio ativo, k de grupo pequeno) em
    // docs/HISTORICO-DECISOES.md. ponytail: scrub de metadado (WK noturno) ou
    // Cloud Function se um dia precisar fechar o residual.
    // ============================================================
    match /pesquisasClima/{pid} {
      function gpClima() { return isAdmin() || temCap('pesquisas.gerenciar', isRH()); }
      function pai() { return get(/databases/$(database)/documents/pesquisasClima/$(pid)).data; }
      function meuReciboNasceuAgora() {
        return !exists(/databases/$(database)/documents/pesquisasClima/$(pid)/recibos/$(request.auth.uid))
            && existsAfter(/databases/$(database)/documents/pesquisasClima/$(pid)/recibos/$(request.auth.uid));
      }

      // Config: gestor le tudo; colaborador le SO as abertas que casam o publico (a
      // query do cliente filtra igual, senao a regra de list nega).
      allow read: if gpClima()
                  || (isAuthed() && resource.data.status == 'aberta' && casaSegmento(resource.data.publico));
      allow create: if gpClima()
        && request.resource.data.criadoPor == request.auth.uid
        && request.resource.data.criadoEm == request.time
        && request.resource.data.status == 'rascunho'
        && request.resource.data.titulo is string
        && request.resource.data.titulo.size() >= 1 && request.resource.data.titulo.size() <= 120
        && request.resource.data.anonima is bool
        && request.resource.data.incluiEnps is bool
        && request.resource.data.incluiAberta is bool
        && request.resource.data.dimensoes is list && request.resource.data.dimensoes.size() <= 12
        && request.resource.data.publico.tipo in ['todos', 'turno', 'setor']
        && request.resource.data.publico.valores is list;
      // 3 ramos: (1) editar rascunho ou ABRIR (cria contador no mesmo batch);
      // (2) aberta, so estender a janela (fim); (3) aberta -> encerrada (one-way).
      // O hasOnly por ramo congela anonima/dimensoes/publico/titulo apos aberta;
      // encerrada nao tem ramo (imutavel). One-way do status e seguranca: sem ele o
      // gestor encerra, le e reabre pra ver as respostas chegando uma a uma.
      allow update: if gpClima() && (
        ( resource.data.status == 'rascunho'
          && request.resource.data.criadoPor == resource.data.criadoPor
          && request.resource.data.criadoEm == resource.data.criadoEm
          && request.resource.data.anonima is bool
          && request.resource.data.status in ['rascunho', 'aberta']
          && ( request.resource.data.status == 'rascunho'
               || ( existsAfter(/databases/$(database)/documents/pesquisasClima/$(pid)/meta/contador)
                    && request.resource.data.abertaEm == request.time
                    && request.resource.data.abertaPor == request.auth.uid ) ) )
        ||
        ( resource.data.status == 'aberta'
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['fim']) )
        ||
        ( resource.data.status == 'aberta'
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'encerradaEm', 'encerradaPor'])
          && request.resource.data.status == 'encerrada'
          && request.resource.data.encerradaEm == request.time
          && request.resource.data.encerradaPor == request.auth.uid )
      );
      allow delete: if isAdmin() || (gpClima() && resource.data.status == 'rascunho');

      // Contador (so o total; NAO e agregado). Gestor le o progresso; o respondente
      // incrementa +1 UMA vez, no batch em que o SEU recibo nasce. Gestor sem update
      // (senao inflava n e destravava o k). increment(1) do SDK avalia o valor final.
      match /meta/contador {
        allow read: if gpClima();
        allow create: if gpClima()
          && request.resource.data.keys().hasOnly(['n']) && request.resource.data.n == 0;
        allow update: if isAuthed()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['n'])
          && request.resource.data.n == resource.data.n + 1
          && meuReciboNasceuAgora();
        allow delete: if false;
      }

      // Recibo: SO marca que aquele uid entregou (dedup + "voce ja respondeu" +
      // veiculo da elegibilidade). Zero conteudo. SELF-ONLY: o gestor NUNCA le (o
      // createTime do recibo entregaria o horario -> correlacao com a resposta).
      match /recibos/{uid} {
        function podeCriarRecibo() {
          let p = pai();
          return isAuthed() && request.auth.uid == uid
            && request.resource.data.keys().hasOnly(['em'])
            && request.resource.data.em == request.time
            && p.status == 'aberta'
            && ( !('fim' in p) || request.time < p.fim )
            && casaSegmento(p.publico);
        }
        allow read: if isAuthed() && request.auth.uid == uid;
        allow create: if podeCriarRecibo();
        allow update, delete: if false;
      }

      // Respostas. Anonima: rid = auto-id, payload SEM identidade e SEM tempo; a
      // elegibilidade e provada pelo recibo que nasce no MESMO batch (nao precisa de
      // uid no doc). Gestor le anonima SO encerrada + n>=5 (k CRAVADO na regra).
      // Imutavel (responder e ato unico, mesma liturgia de assinaturas).
      match /respostas/{rid} {
        function conteudoOk() {
          return request.resource.data.notas is map
            && request.resource.data.notas.size() >= 1 && request.resource.data.notas.size() <= 40
            && ( !('enps' in request.resource.data)
                 || (request.resource.data.enps is int
                     && request.resource.data.enps >= 0 && request.resource.data.enps <= 10) )
            && ( !('comentario' in request.resource.data)
                 || (request.resource.data.comentario is string
                     && request.resource.data.comentario.size() <= 1000) );
        }
        function podeCriar() {
          let p = pai();
          // Disjuncao EXPLICITA (nao ternario): lixo em 'anonima' (string/null/num) tem que
          // NEGAR, nao cair num default. anonima e o campo do gate de LGPD (ressalva Fable).
          return isAuthed() && p.status == 'aberta' && meuReciboNasceuAgora() && conteudoOk()
            && ( ( p.anonima == true
                   && rid != request.auth.uid
                   && request.resource.data.keys().hasOnly(['notas', 'enps', 'comentario']) )
                 || ( p.anonima == false
                      && rid == request.auth.uid
                      && request.resource.data.uid == request.auth.uid
                      && request.resource.data.respondidoEm == request.time
                      && request.resource.data.keys().hasOnly(['uid', 'notas', 'enps', 'comentario', 'respondidoEm']) ) );
        }
        function podeLer() {
          let p = pai();
          return ( gpClima()
                   && ( p.anonima == false
                        || ( p.status == 'encerrada'
                             && get(/databases/$(database)/documents/pesquisasClima/$(pid)/meta/contador).data.n >= 5 ) ) )
                 || ( p.anonima == false && isAuthed() && request.auth.uid == rid );
        }
        allow read: if podeLer();
        allow create: if podeCriar();
        allow update, delete: if false;
      }
    }

    // ============================================================
    // AVALIACAO DE DESEMPENHO (feature 2 das Avaliacoes, 2026-07-09).
    // v1 = modalidades 'gestor' (so o gestor avalia) e 'auto' (gestor +
    // autoavaliacao lado a lado); o '360' de pares anonimos FICA FORA ate
    // existir Cloud Functions (sorteio/agregacao server-side; decisao do
    // William). RH/admin cria os ciclos (cap desempenho.gerenciar, GLOBAL:
    // NUNCA conceder 'turno'/'atrib'); o gestor avalia SO alvos do proprio
    // escopo (lider por turno, supervisor por lista/turnos, validado NA REGRA
    // via users/{alvoUid} denormalizado, mesmos campos do casaSegmento); o
    // colaborador faz a autoavaliacao e le o que e sobre si SO concluido.
    // Sem PII denormalizada no doc (identidade via funcionarios no runtime).
    // Gaps gestor x auto calculados no cliente; por isso NAO ha colecao
    // 'resultados' no v1 (ela e do 360 server-side).
    // ============================================================
    match /avaliacaoCiclos/{cicloId} {
      function gpDesemp() { return isAdmin() || temCap('desempenho.gerenciar', isRH()); }
      function ciclo() { return get(/databases/$(database)/documents/avaliacaoCiclos/$(cicloId)).data; }
      // O ALVO e chaveado por funcionarioId (nao uid de users): o gestor opera por
      // state.funcionarios e nao conhece uids; os helpers do projeto (supervisorVe,
      // meuFuncionarioId, euSouODono) ja sao por fid. funcionarios/{fid} tem turno/setor.
      function alvoFunc(fid) { return get(/databases/$(database)/documents/funcionarios/$(fid)).data; }
      // Escopo do gestor sobre o alvo. Campo ausente no doc do alvo = erro = nega (fail-safe).
      function gestorNoEscopo(fid) {
        let a = alvoFunc(fid);
        return gpDesemp()
          || liderDoMesmoTurno(a.turno)
          || supervisorVe(fid)
          || supervisorVeTurno(a.turno);
      }
      // O alvo participa do ciclo? (casaTurno/casaSetor ja recebem o doc por argumento)
      function alvoNoPublico(fid) {
        let c = ciclo();
        let a = alvoFunc(fid);
        return c.publico.tipo == 'todos'
          || (c.publico.tipo == 'turno' && casaTurno(c.publico, a))
          || (c.publico.tipo == 'setor' && casaSetor(c.publico, a));
      }
      function cicloShapeOk() {
        return request.resource.data.nome is string
          && request.resource.data.nome.size() >= 1 && request.resource.data.nome.size() <= 120
          && request.resource.data.modalidade in ['gestor', 'auto']
          && request.resource.data.competencias is list
          && request.resource.data.competencias.size() >= 1 && request.resource.data.competencias.size() <= 12
          && request.resource.data.escalaMax is int
          && request.resource.data.escalaMax >= 3 && request.resource.data.escalaMax <= 10
          && request.resource.data.periodoInicio is timestamp
          && request.resource.data.periodoFim is timestamp
          && request.resource.data.publico.tipo in ['todos', 'turno', 'setor']
          && request.resource.data.publico.valores is list;
      }

      // Config: papel de gestao le (precisa pra avaliar); colaborador le ciclo ATIVO
      // (pra se autoavaliar) OU ENCERRADO (pra rotular o proprio resultado, que so
      // aparece no fechamento) em que participa. Rascunho o colaborador nunca le.
      allow read: if gpDesemp() || isLider() || isSupervisor()
                  || (isAuthed() && resource.data.status in ['ativo', 'encerrado'] && casaSegmento(resource.data.publico));
      allow create: if gpDesemp()
        && request.resource.data.status == 'rascunho'
        && request.resource.data.criadoPor == request.auth.uid
        && request.resource.data.criadoEm == request.time
        && cicloShapeOk();
      // 3 ramos (espelho do clima): editar rascunho ou ATIVAR; ativo so estende o
      // periodoFim; ativo -> encerrado one-way. Congela modalidade/competencias/
      // escalaMax/publico depois de ativo; encerrado e imutavel.
      allow update: if gpDesemp() && (
        ( resource.data.status == 'rascunho'
          && request.resource.data.criadoPor == resource.data.criadoPor
          && request.resource.data.criadoEm == resource.data.criadoEm
          && cicloShapeOk()
          && request.resource.data.status in ['rascunho', 'ativo']
          && ( request.resource.data.status == 'rascunho'
               || ( request.resource.data.ativadoEm == request.time
                    && request.resource.data.ativadoPor == request.auth.uid ) ) )
        ||
        ( resource.data.status == 'ativo'
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['periodoFim'])
          && request.resource.data.periodoFim is timestamp )
        ||
        ( resource.data.status == 'ativo'
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'encerradoEm', 'encerradoPor'])
          && request.resource.data.status == 'encerrado'
          && request.resource.data.encerradoEm == request.time
          && request.resource.data.encerradoPor == request.auth.uid )
      );
      allow delete: if isAdmin() || (gpDesemp() && resource.data.status == 'rascunho');

      // Avaliacoes: id DETERMINISTICO "{papel}_{alvoFid}" -- UMA avaliacao de gestor
      // (a oficial do ciclo) e UMA auto por alvo; re-salvar nao duplica e todo mundo
      // acha o doc por getDoc direto, sem query. avaliadorUid registra o ULTIMO autor
      // (outro gestor do escopo pode assumir o rascunho). papel 'auto' so na
      // modalidade 'auto' e so o proprio (participando do publico); papel 'gestor'
      // so gestor com o alvo no escopo E no publico do ciclo. Escrita so com ciclo
      // ATIVO; 'concluida' e imutavel (correcao administrativa = delete do gp, com
      // trilha em /eventos pela UI).
      match /avaliacoes/{avId} {
        function d() { return request.resource.data; }
        function avShapeOk() {
          return d().keys().hasOnly(['alvoFid', 'avaliadorUid', 'papel', 'notas', 'comentarios', 'feedbackGeral', 'status', 'atualizadoEm'])
            && d().alvoFid is string && d().avaliadorUid is string
            && d().papel in ['gestor', 'auto']
            && avId == d().papel + '_' + d().alvoFid
            && d().avaliadorUid == request.auth.uid
            && d().notas is map && d().notas.size() >= 1 && d().notas.size() <= 12
            && ( !('comentarios' in d()) || d().comentarios is map )
            && ( !('feedbackGeral' in d()) || (d().feedbackGeral is string && d().feedbackGeral.size() <= 2000) )
            && d().status in ['rascunho', 'concluida']
            && d().atualizadoEm == request.time;
        }
        function podeEscrever() {
          let c = ciclo();
          // request.time < periodoFim: sem isto o ramo "estender periodoFim" seria
          // decorativo e o ciclo ativo aceitaria avaliacao pra sempre (gate Fable).
          return isAuthed() && c.status == 'ativo' && request.time < c.periodoFim && avShapeOk()
            && (resource == null || resource.data.status == 'rascunho')
            && ( ( d().papel == 'auto'
                   && c.modalidade == 'auto'
                   && d().alvoFid == meuFuncionarioId()
                   && casaSegmento(c.publico) )
                 ||
                 ( d().papel == 'gestor'
                   && d().alvoFid != meuFuncionarioId()
                   && gestorNoEscopo(d().alvoFid)
                   && alvoNoPublico(d().alvoFid) ) );
        }
        // Le: o avaliador/autor a propria (qualquer status); gp tudo; o ALVO a que e
        // sobre si SO concluida E com o ciclo ENCERRADO (decisao William 2026-07-09:
        // o resultado chega pra todo mundo junto, no fechamento; um concluir
        // acidental do gestor nao expoe nada); o gestor do escopo le as concluidas
        // do escopo durante o ciclo (comparativo gestor x auto). Rascunho alheio
        // ninguem le.
        allow read: if isAuthed() && (
          resource.data.avaliadorUid == request.auth.uid
          || gpDesemp()
          || (resource.data.alvoFid == meuFuncionarioId() && resource.data.status == 'concluida'
              && ciclo().status == 'encerrado')
          || (resource.data.status == 'concluida' && gestorNoEscopo(resource.data.alvoFid))
        );
        allow create: if podeEscrever();
        allow update: if podeEscrever();
        allow delete: if gpDesemp();
      }
    }
  }
}
