rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ----- Helpers -----

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function isAuthed() {
      return request.auth != null;
    }
    function isAdmin() {
      return isAuthed() && userDoc().role == 'admin';
    }
    function isRH() {
      return isAuthed() && userDoc().role == 'rh';
    }
    function isLider() {
      return isAuthed() && userDoc().role == 'lider';
    }
    function isSupervisor() {
      return isAuthed() && userDoc().role == 'supervisor';
    }
    function supervisorVe(funcId) {
      return isSupervisor()
        && userDoc().funcionariosVisiveis is list
        && userDoc().funcionariosVisiveis.hasAny([funcId]);
    }
    function liderDoMesmoTurno(turno) {
      return isLider() && userDoc().turno == turno;
    }
    // READ amplo: supervisor lê todas as ocorrências (a UI filtra pela lista
    // dele). O escopo estrito (supervisorVe) é aplicado só no WRITE/conferir.
    function podeVerOcorrencia(doc) {
      return isAdmin() || isRH()
        || liderDoMesmoTurno(doc.funcionarioTurno)
        || isSupervisor();
    }

    // ----- users -----
    // Admin lê todos; user lê só o próprio doc.
    // Admin cria/deleta/edita qualquer campo. O próprio user pode atualizar
    // APENAS o campo fotoBase64 (foto de perfil) — sem poder mexer em role,
    // turno, ativo. Rule garante isolamento mesmo se a UI for burlada.
    match /users/{uid} {
      // Leitura liberada pra autenticados: o chat precisa do diretório
      // (nome/papel/foto) pra listar e mandar mensagem pra qualquer um.
      // Docs não têm segredos (sem senha; PII real fica em banco-horas-saldos).
      allow read: if isAuthed();
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (
        request.auth.uid == uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['fotoBase64'])
      );
    }

    // ----- funcionarios -----
    match /funcionarios/{id} {
      allow read: if isAuthed();
      allow create, update, delete: if isAdmin() || isRH();
    }

    // ----- tipos (motivos customizados criados pela equipe) -----
    // Todos logados leem (pra popular o dropdown). Admin/RH criam/excluem.
    match /tipos/{id} {
      allow read: if isAuthed();
      allow create, update, delete: if isAdmin() || isRH();
    }

    // ----- acoes (ações customizadas — encaminhamento pelo líder) -----
    // Mesma lógica de tipos.
    match /acoes/{id} {
      allow read: if isAuthed();
      allow create, update, delete: if isAdmin() || isRH();
    }

    // ----- bancoHoras (saldo de horas por funcionário · denormalizado por doc) -----
    // Admin/RH leem tudo (na prática usam /pipeline-rh/cur direto agora).
    // Líder lê apenas docs do próprio turno — query DEVE incluir
    // .where("funcionarioTurno", "==", u.turno) pro Firestore aceitar a lista.
    // Escrita: pipeline RH (servidor) ou admin/RH via UI.
    match /bancoHoras/{funcionarioId} {
      allow read: if isAdmin() || isRH()
                  || (isLider() && resource.data.funcionarioTurno == userDoc().turno)
                  || isSupervisor();
      allow create, update, delete: if isAdmin() || isRH();
    }

    // ----- pj (controle de prestadores de serviço) -----
    // Apenas admin e RH leem/escrevem. Líderes não têm acesso.
    match /pj/{id} {
      allow read, create, update, delete: if isAdmin() || isRH();
    }

    // ----- presence (quem está online agora) -----
    // Leitura: qualquer usuário autenticado (pra renderizar o indicador).
    // Escrita/delete: só o próprio user no próprio documento (uid = doc id).
    // Campos esperados: { uid, nome, role, page, lastSeen (timestamp) }
    match /presence/{uid} {
      allow read: if isAuthed();
      allow create, update, delete: if isAuthed() && request.auth.uid == uid;
    }

    // ----- mensagens (chat interno · TTL 3 dias via expiraEm) -----
    match /mensagens/{id} {
      allow read: if isAuthed()
        && (resource.data.de == request.auth.uid || resource.data.para == request.auth.uid);
      allow create: if isAuthed()
        && request.resource.data.de == request.auth.uid
        && request.resource.data.texto is string
        && request.resource.data.texto.size() > 0
        && request.resource.data.texto.size() <= 2000
        && request.resource.data.para is string
        && request.resource.data.parKey is string;
      // destinatário marca como lida (só o campo 'lido')
      allow update: if isAuthed()
        && resource.data.para == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lido']);
      // remetente pode apagar a própria msg (TTL cuida do resto)
      allow delete: if isAuthed() && resource.data.de == request.auth.uid;
    }

    // ----- ocorrencias -----
    match /ocorrencias/{id} {
      allow read: if podeVerOcorrencia(resource.data);

      // Criar: RH ou admin. Campos obrigatórios e turno coerente.
      // funcionarioTurno aceita 1, 2, 3 (turnos numerados) e "geral"
      // (quadro de horário comercial sem turno fixo). null não é
      // aceito pra forçar o RH a definir o turno do funcionário antes.
      allow create: if (isRH() || isAdmin())
        && request.resource.data.criadoPor == request.auth.uid
        && request.resource.data.acao == null
        && request.resource.data.dataConferencia == null
        && request.resource.data.funcionarioId is string
        && request.resource.data.funcionarioTurno in [1, 2, 3, 'geral']
        && request.resource.data.tipo is string
        && request.resource.data.horario is string;

      allow update: if
        isAdmin()
        || (isRH() && podeAtualizarApenasObservacao())
        || (liderDoMesmoTurno(resource.data.funcionarioTurno)
            && podeConferirOuAtualizarObs())
        || (isSupervisor()
            && supervisorVe(resource.data.funcionarioId)
            && podeConferirOuAtualizarObs());

      allow delete: if isAdmin() || isRH();
    }

    // ----- banco-horas-saldos -----
    // Snapshot rico com CPF/PIS · só admin + RH leem · escrita via Admin SDK
    match /banco-horas-saldos/{funcId} {
      allow read: if isAdmin() || isRH();
      allow write: if false;
    }

    // ----- banco-horas -----
    // Histórico mensal de lançamentos diários · admin + RH leem
    match /banco-horas/{docId} {
      allow read: if isAdmin() || isRH();
      allow write: if false;
    }

    // ----- pipeline-rh (estrutura cur/hist · espelho do Comercial · SEM PII) -----
    // ⚠️ É um doc único com TODOS os funcionários ativos num array — não
    // dá pra filtrar por turno via rule. Por isso: admin+RH only.
    // Líder NÃO lê daqui; lê de /bancoHoras filtrado pelo turno (ver abaixo).
    // Docs: pipeline-rh/cur (mês corrente + meta) e pipeline-rh/hist (meses fechados).
    match /pipeline-rh/{docId} {
      allow read: if isAdmin() || isRH();
      allow write: if false;
    }

    // ----- Helpers de atualização -----

    // RH pode mexer em: observacao, historico, atualizadoEm, e nos
    // campos de lançamento (lancada/lancadoEm/lancadoPor). Não pode
    // alterar data/funcionário/tipo/horário/ação/conferência.
    function podeAtualizarApenasObservacao() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['observacao', 'historico', 'atualizadoEm',
                  'lancada', 'lancadoEm', 'lancadoPor']);
    }

    function podeConferirOuAtualizarObs() {
      let allowedKeys = ['observacao', 'historico', 'atualizadoEm',
                         'acao', 'dataConferencia', 'conferidoPor'];
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      let mudancasPermitidas = changed.hasOnly(allowedKeys);
      let acaoOk = !changed.hasAny(['acao']) || resource.data.acao == null;
      let dataOk = !changed.hasAny(['dataConferencia']) || resource.data.dataConferencia == null;
      return mudancasPermitidas && acaoOk && dataOk;
    }
  }
}
