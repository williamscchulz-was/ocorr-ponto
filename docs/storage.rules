rules_version = '2';

// ============================================================
// Firebase Storage — FioPulse
//
// IMPORTANTE: as regras do Storage NÃO conseguem ler o Firestore. Então o controle
// de acesso ao ARQUIVO depende de CUSTOM CLAIMS no token do usuário (role, funcionarioId),
// setadas pelo pipeline (WKRADAR, admin SDK) no provisionamento. Sem a claim,
// request.auth.token.role / .funcionarioId vêm indefinidos => nega (fail-safe).
// O app força getIdToken(true) pra pegar as claims novas.
// ============================================================

service firebase.storage {
  match /b/{bucket}/o {

    function gestor() {
      return request.auth != null
        && (request.auth.token.role == 'admin' || request.auth.token.role == 'rh');
    }
    function ehDono(funcionarioId) {
      return request.auth != null
        && request.auth.token.funcionarioId == funcionarioId;
    }

    // recibos/{funcionarioId}/original/{arquivo}
    //   O arquivo importado (quando migrar do Firestore pro Storage). Gestor grava;
    //   colaborador lê SÓ o do próprio funcionarioId (claim). Só PDF, teto 10 MB.
    match /recibos/{funcionarioId}/original/{arquivo} {
      allow read:  if gestor() || ehDono(funcionarioId);
      allow write: if gestor()
        && (request.resource == null
            || (request.resource.contentType == 'application/pdf'
                && request.resource.size < 10 * 1024 * 1024));
    }

    // recibos/{funcionarioId}/assinado/{arquivo}
    //   A versão CARIMBADA (Fase B), gravada pelo PRÓPRIO colaborador no ato de assinar.
    //   CREATE-ONLY de verdade (resource == null): depois de assinado, NINGUÉM sobrescreve
    //   nem apaga pelo cliente — nem gestor (retenção/estorno é só via Admin, deliberado).
    match /recibos/{funcionarioId}/assinado/{arquivo} {
      allow read:  if gestor() || ehDono(funcionarioId);
      allow write: if ehDono(funcionarioId)
        && resource == null
        && request.resource != null
        && request.resource.contentType == 'application/pdf'
        && request.resource.size < 10 * 1024 * 1024;
    }

    // documentos-assinados/{funcionarioId}/{arquivo}
    //   Comprovante A4 da assinatura eletrônica de um documento institucional
    //   (confirmacao == 'assinatura'), gerado e gravado pelo PRÓPRIO colaborador no
    //   ato de assinar. CREATE-ONLY (resource == null): depois de assinado, ninguém
    //   sobrescreve nem apaga pelo cliente. Espelha recibos/{funcionarioId}/assinado.
    //   O nome do arquivo carrega a versão do documento ({docId}-v{n}.pdf), então cada
    //   versão vira um comprovante distinto sem violar o create-only.
    match /documentos-assinados/{funcionarioId}/{arquivo} {
      allow read:  if gestor() || ehDono(funcionarioId);
      allow write: if ehDono(funcionarioId)
        && resource == null
        && request.resource != null
        && request.resource.contentType == 'application/pdf'
        && request.resource.size < 10 * 1024 * 1024;
    }

    // curriculos/{arquivo}
    //   Curriculo de CANDIDATO EXTERNO (site publico de vagas, SEM login): a UNICA
    //   escrita anonima do Storage, e por isso um funil: CREATE-ONLY (resource ==
    //   null, ninguem sobrescreve curriculo alheio nem o proprio), so PDF, teto
    //   3 MB, nome sano (sem barra; o cliente gera {vagaId}__{email}__{rand}.pdf e
    //   grava o path no campo curriculoPath da candidatura, que e o vinculo real).
    //   Leitura e exclusao SO GP (nem o proprio anonimo rele o que subiu); o
    //   expurgo LGPD da candidatura apaga o arquivo pelo path gravado.
    //   Residual aceito (mesma classe do gate das candidaturas): bot pode subir
    //   PDFs variando nomes; teto 3MB + budget alert + poda manual da GP.
    //   ponytail: App Check/Functions se abusarem.
    match /curriculos/{arquivo} {
      allow read, delete: if gestor();
      allow create: if resource == null
        && request.resource != null
        && request.resource.contentType == 'application/pdf'
        && request.resource.size < 3 * 1024 * 1024
        && arquivo.matches('[A-Za-z0-9@._-]+\\.pdf');
      allow update: if false;
    }

    // Qualquer outro caminho: negado por padrão (não precisa de match explícito).
  }
}
